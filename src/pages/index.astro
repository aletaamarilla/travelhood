---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar";
import SearchIsland from "@/components/SearchIsland";
import LastChance from "@/components/LastChance.astro";
import SeasonExplorer from "@/components/SeasonExplorer";
import WhyUsSection from "@/components/WhyUsSection.astro";
import HowItWorksSection from "@/components/HowItWorksSection.astro";
import TestimonialsSection from "@/components/TestimonialsSection.astro";
import AboutSection from "@/components/AboutSection.astro";
import LeadMagnet from "@/components/LeadMagnet";

import FAQSection from "@/components/FAQSection";
import CTAFooter from "@/components/CTAFooter.astro";
import InternalLinks from "@/components/InternalLinks.astro";
import Footer from "@/components/Footer.astro";
import { generateTravelAgencySchema, generateAggregateRatingSchema, generateWebSiteSchema, toJsonLd } from "@/lib/schemas";
import { getTestimonials, getDestinations, getTrips, getContinents } from "@/lib/data-provider";
const [testimonials, destinations, trips, continents] = await Promise.all([
  getTestimonials(), getDestinations(), getTrips(), getContinents()
]);
import GEODataBlock from "@/components/GEODataBlock.astro";

const agencySchema = generateTravelAgencySchema();
const agencyWithRating = {
  ...agencySchema,
  aggregateRating: generateAggregateRatingSchema(testimonials.length),
};
const webSiteSchema = generateWebSiteSchema();
---

<Layout>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(agencyWithRating)} />
    <script type="application/ld+json" set:html={toJsonLd(webSiteSchema)} />
  </Fragment>
  <main>
    <Navbar client:load />
    <SearchIsland destinations={destinations} continents={continents} client:load />
    <LastChance />
    <WhyUsSection />
    <SeasonExplorer trips={trips} destinations={destinations} client:load />
    <HowItWorksSection />
    <TestimonialsSection />
    <AboutSection />
    <GEODataBlock
      title="Viajes en grupo para jóvenes — Datos clave"
      subtitle="Información actualizada sobre viajes organizados con Travelhood"
      dataPoints={[
        { label: "Destinos", value: `${destinations.length} destinos` },
        { label: "Rango de precios", value: "590€ – 1.590€ (sin vuelo)" },
        { label: "Grupo medio", value: "14 personas de 20 a 35 años" },
        { label: "Viajan solos", value: "El 70% reservan sin acompañante" },
        { label: "Repiten", value: "El 98% de los viajeros repiten" },
        { label: "Incluye", value: "Coordinador + alojamiento + seguro" },
      ]}
    />
    <LeadMagnet client:visible />
    <FAQSection client:visible />
    <CTAFooter />
    <InternalLinks />
    <Footer />
  </main>

  <!-- Floating bottom bar (mobile only) -->
  <div class="fixed bottom-0 left-0 right-0 z-50 border-t border-sand/10 bg-teal-deep/95 backdrop-blur-lg px-4 py-3 shadow-[0_-4px_20px_rgba(0,0,0,0.15)] lg:hidden">
    <div class="mx-auto flex max-w-lg items-center gap-3">
      <a
        href="/viajes/#resultados"
        class="flex-1 inline-flex items-center justify-center gap-2 rounded-full bg-coral px-5 py-3 text-sm font-bold text-white transition-all hover:brightness-110"
      >
        Ver viajes
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
      </a>
      <a
        href="https://wa.me/34600000000?text=Hola!%20Me%20interesa%20saber%20m%C3%A1s%20sobre%20vuestros%20viajes"
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-5 py-3 text-sm font-bold text-white transition-all hover:brightness-110"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </a>
    </div>
  </div>

  <!-- Floating WhatsApp button (desktop only) -->
  <a
    href="https://wa.me/34600000000?text=Hola!%20Me%20interesa%20saber%20m%C3%A1s%20sobre%20vuestros%20viajes"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Escríbenos por WhatsApp"
    class="fixed bottom-6 right-6 z-50 hidden h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-lg transition-all hover:scale-110 hover:shadow-xl lg:flex"
  >
    <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
</Layout>
