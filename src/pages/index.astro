---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import SearchIsland from "@/components/SearchIsland";
import LastChance from "@/components/LastChance.astro";
import SeasonExplorer from "@/components/SeasonExplorer";
import WhyUsSection from "@/components/WhyUsSection.astro";
import HowItWorksSection from "@/components/HowItWorksSection.astro";
import TestimonialsSection from "@/components/TestimonialsSection.astro";
import AboutSection from "@/components/AboutSection.astro";
import LeadMagnet from "@/components/LeadMagnet";

import FAQSection from "@/components/FAQSection";
import CTAFooter from "@/components/CTAFooter.astro";
import Footer from "@/components/Footer.astro";
import { generateTravelAgencySchema, generateWebSiteSchema, toJsonLd } from "@/lib/schemas";
import { getTrips, getSearchCatalog, getSiteSettings, resolveSettingsImages, getGlobalFaqs, calculatePriceRange, toSearchCatalogDestinations, toSearchCatalogContinents } from "@/lib/data-provider";
import { FALLBACK_WHATSAPP_PHONE, FALLBACK_WA_COMMUNITY_URL, buildWhatsAppUrl } from "@/lib/config";
import { sanityImgSrcset } from "@/lib/utils";
const [{ destinations, continents }, trips, settings, faqBlocks] = await Promise.all([
  getSearchCatalog(), getTrips(), getSiteSettings(), getGlobalFaqs('home')
]);
const homeFaqs = faqBlocks.flatMap((b) => b.faqs);
const images = settings ? resolveSettingsImages(settings) : null;
const waPhone = settings?.whatsappPhone ?? FALLBACK_WHATSAPP_PHONE;
const waCommunityUrl = settings?.whatsappCommunityUrl ?? FALLBACK_WA_COMMUNITY_URL;
import GEODataBlock from "@/components/GEODataBlock.astro";

const priceRange = calculatePriceRange(trips);
const searchDestinations = toSearchCatalogDestinations(destinations);
const searchContinents = toSearchCatalogContinents(continents);
const searchTrips = trips.map(({ destinationId, departureDate, returnDate, status, tags }) => ({
  destinationId,
  departureDate,
  returnDate,
  status,
  tags,
}));
const agencySchema = generateTravelAgencySchema(priceRange?.formatted, {
  type: settings?.legalLicenseType,
  number: settings?.legalLicenseNumber,
});
const webSiteSchema = generateWebSiteSchema();
---

<Layout>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(agencySchema)} />
    <script type="application/ld+json" set:html={toJsonLd(webSiteSchema)} />
  </Fragment>
  <main>
    <Navbar solid logoUrl={images?.orgLogoUrl} />
    <section class={`relative ${!images?.homeHeroImage ? 'bg-gradient-to-br from-teal-deep to-teal-deep/80' : ''}`}>
      {images?.homeHeroImage && (
        <img
          src={images.homeHeroImage}
          srcset={sanityImgSrcset(images.homeHeroImage)}
          sizes="100vw"
          alt={images?.homeHeroImageAlt || "Paisaje de aventura"}
          width="1920"
          height="1080"
          class="absolute inset-0 h-full w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
      )}
      <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/15 to-black/55"></div>
      <div class="relative z-10 flex min-h-[55vh] flex-col items-center px-6 pt-24 sm:min-h-[58vh] sm:pt-28 lg:min-h-[65vh]">
        <div class="mx-auto flex w-full max-w-3xl flex-1 flex-col items-center justify-center gap-5 text-center">
          <h1 class="font-serif text-[2.25rem] font-bold leading-[1.12] tracking-tight text-white sm:text-5xl lg:text-[3.5rem]">
            Tú pones las ganas,<br />nosotros el grupo.
          </h1>
          <p class="max-w-md text-base text-white/85 leading-relaxed sm:text-lg">
            Viaja en grupos reducidos con personas de tu edad. Itinerario, alojamiento y coordinador incluidos.
          </p>
        </div>
        <div class="z-20 mx-auto w-full max-w-2xl translate-y-1/2">
          <p class="mb-3 text-center text-[13px] tracking-wide text-white/65">
            +500 viajeros · {destinations.length} destinos · Coordinador en destino
          </p>
          <SearchIsland destinations={searchDestinations} continents={searchContinents} trips={searchTrips} client:load />
        </div>
      </div>
    </section>
    <LastChance />
    <WhyUsSection bgImage={images?.homeWhyUsImage} />
    <SeasonExplorer trips={trips} destinations={destinations} client:visible />
    <section class="bg-background py-12">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="grid gap-6 rounded-3xl border border-border/40 bg-card p-6 shadow-sm sm:p-8 lg:grid-cols-[1fr_auto] lg:items-center">
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-secondary">Para grupos que ya se tienen</span>
            <h2 class="mt-3 font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
              ¿No os encaja ninguna salida? Pedid un viaje privado.
            </h2>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base">
              Si ya tenéis grupo de amigos, clase, academia o compañeros, Travelhood puede ayudaros a montar una propuesta privada por WhatsApp.
            </p>
          </div>
          <a
            href="/viajes-privados/"
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-teal-deep px-6 py-3 text-sm font-bold text-sand transition-all hover:-translate-y-0.5 hover:shadow-md"
          >
            Ver viajes privados para grupos
          </a>
        </div>
      </div>
    </section>
    <HowItWorksSection bgImage={images?.homeHowItWorksImage} />
    <TestimonialsSection />
    <AboutSection bgImage={images?.homeAboutBgImage} photo={images?.homeAboutPhoto} photoAlt={images?.homeAboutPhotoAlt} />
    <GEODataBlock
      title="Viajes en grupo para jóvenes — Datos clave"
      subtitle="Información actualizada sobre viajes organizados con Travel Hood"
      dataPoints={[
        { label: "Destinos", value: `${destinations.length} destinos` },
        { label: "Rango de precios", value: priceRange ? `${priceRange.formatted} (sin vuelo)` : "Consulta precios" },
        { label: "Grupo", value: "12-13 personas de 20 a 35 años" },
        { label: "Viajan solos", value: "La mayoría reservan sin acompañante" },
        { label: "Incluye", value: "Coordinador + alojamiento + actividades" },
        { label: "Precio cerrado", value: "Sin fondo común ni costes extra" },
      ]}
    />
    <LeadMagnet client:visible whatsappCommunityUrl={waCommunityUrl} />
    <FAQSection client:visible faqs={homeFaqs} />
    <CTAFooter />
    <Footer />
  </main>

  <!-- Floating bottom bar (mobile only) -->
  <div class="fixed bottom-0 left-0 right-0 z-50 border-t border-sand/10 bg-teal-deep/95 backdrop-blur-lg will-change-transform px-4 py-3 shadow-[0_-4px_20px_rgba(0,0,0,0.15)] lg:hidden">
    <div class="mx-auto flex max-w-lg items-center gap-3">
      <a
        href="/viajes/#resultados"
        class="flex-1 inline-flex items-center justify-center gap-2 rounded-full bg-coral px-5 py-3 text-sm font-bold text-white transition-all hover:brightness-110"
      >
        Ver viajes
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
      </a>
      <a
        href={buildWhatsAppUrl(waPhone, "Hola! Me interesa saber más sobre vuestros viajes")}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-5 py-3 text-sm font-bold text-white transition-all hover:brightness-110"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </a>
    </div>
  </div>

  <!-- Floating WhatsApp button (desktop only) -->
  <a
    href={buildWhatsAppUrl(waPhone, "Hola! Me interesa saber más sobre vuestros viajes")}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Escríbenos por WhatsApp"
    class="fixed bottom-6 right-6 z-50 hidden h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-lg transition-all hover:scale-110 hover:shadow-xl lg:flex"
  >
    <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
</Layout>
