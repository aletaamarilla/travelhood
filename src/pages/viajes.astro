---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import SearchPage from "@/components/SearchPage";
import Footer from "@/components/Footer.astro";
import { generateBreadcrumbSchema, generateItemListSchema, toJsonLd } from "@/lib/schemas";
import { getDestinations, getTrips, getContinents, getCountries, getSiteSettings, resolveSettingsImages } from "@/lib/data-provider";
import { FALLBACK_WHATSAPP_PHONE } from "@/lib/config";
const [destinations, trips, continents, countries, viajesSettings] = await Promise.all([
  getDestinations(), getTrips(), getContinents(), getCountries(), getSiteSettings()
]);
const viajesImages = viajesSettings ? resolveSettingsImages(viajesSettings) : null;
const waPhone = viajesSettings?.whatsappPhone ?? FALLBACK_WHATSAPP_PHONE;
---

<Layout
  title="Viajes en grupo 2026 — Encuentra tu aventura | Travel Hood"
  description="Explora todos los viajes en grupo de Travel Hood para jóvenes de 20-35 años. Filtra por destino, fecha y tipo de experiencia. Coordinador y alojamiento incluidos."
  keywords="viajes en grupo 2026, viajes organizados jóvenes, viajes para singles, buscar viaje grupo, travel hood viajes, travelhood viajes"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:"Viajes",url:"/viajes/"}]))} />
    <script type="application/ld+json" set:html={toJsonLd(generateItemListSchema({name:"Todos los destinos Travel Hood",items:destinations.map((d,i)=>({name:d.name,url:`/destino/${d.slug}/`,position:i+1}))}))} />
  </Fragment>
  <main>
    <Navbar solid />
    <SearchPage trips={trips} destinations={destinations} continents={continents} countries={countries} heroImage={viajesImages?.viajes_heroImage} heroImageAlt={viajesImages?.viajes_heroImageAlt} whatsappPhone={waPhone} client:load />
    <Footer />
  </main>
</Layout>
