---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer.astro";
import ContinentFAQ from "@/components/ContinentFAQ";
import LeadMagnet from "@/components/LeadMagnet";
import GEODataBlock from "@/components/GEODataBlock.astro";
import {
  getSeasons,
  getDestinations,
  getTrips,
  getCountries,
  getTripExtra,
} from "@/lib/data-provider";
import { generateFaqSchema, generateBreadcrumbSchema, generateEventSchema, generateItemListSchema, toJsonLd } from "@/lib/schemas";
import { format } from "date-fns";
import { es } from "date-fns/locale";

export async function getStaticPaths() {
  const allSeasons = await getSeasons();
  return allSeasons.map((s) => ({
    params: { slug: s.slug },
  }));
}

const { slug } = Astro.params;
const [seasons, destinations, trips, countries] = await Promise.all([
  getSeasons(), getDestinations(), getTrips(), getCountries()
]);
const season = seasons.find((s) => s.slug === slug)!;

const now = new Date();
const seasonTrips = trips
  .filter((t) => {
    return (
      season.tags.some((tag) => t.tags.includes(tag)) &&
      t.status !== "full" &&
      new Date(t.departureDate) > now
    );
  })
  .sort(
    (a, b) =>
      new Date(a.departureDate).getTime() - new Date(b.departureDate).getTime()
  );

const hasTrips = seasonTrips.length > 0;

const seasonTripCards = seasonTrips.map((trip) => {
  const dest = destinations.find((d) => d.id === trip.destinationId)!;
  const country = countries.find((c) => c.id === dest.countryId);
  const extra = getTripExtra(trip.id);
  const price = extra.promoPrice ?? trip.promoPrice ?? trip.priceFrom;
  const isUrgent = trip.status === "almost-full" || trip.placesLeft <= 4;
  return {
    destSlug: dest.slug,
    destName: dest.name,
    destImage: dest.heroImage,
    countryFlag: country?.flag.toLowerCase() ?? "",
    countryName: country?.name ?? "",
    title: trip.title,
    dateFormatted: format(new Date(trip.departureDate), "d 'de' MMMM yyyy", { locale: es }),
    durationDays: trip.durationDays,
    price,
    originalPrice: trip.priceFrom,
    hasDiscount: extra.promoPrice != null && extra.promoPrice < trip.priceFrom,
    promoLabel: extra.promoLabel ?? trip.promoLabel,
    isUrgent,
    placesLeft: trip.placesLeft,
    flightEstimate: trip.flightEstimate,
  };
});

const uniqueDestinations = [...new Set(seasonTrips.map((t) => t.destinationId))]
  .map((id) => destinations.find((d) => d.id === id)!)
  .filter(Boolean);
---

<Layout title={season.seoTitle} description={season.seoDescription} ogImage={season.heroImage} keywords={`viajes ${season.name.toLowerCase()} 2026, viajes grupo ${season.name.toLowerCase()}, travelhood ${season.name.toLowerCase()}`}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:"Temporadas",url:"/viajes/"},{name:season.name,url:`/temporada/${season.slug}/`}]))} />
    <script type="application/ld+json" set:html={toJsonLd(generateItemListSchema({name:`Viajes ${season.name}`,items:uniqueDestinations.map((d,i)=>({name:d.name,url:`/destino/${d.slug}/`,position:i+1}))}))} />
    {season.faqs.length > 0 && <script type="application/ld+json" set:html={toJsonLd(generateFaqSchema(season.faqs))} />}
    {seasonTrips.map((trip) => {
      const dest = destinations.find((d) => d.id === trip.destinationId)!;
      const extra = getTripExtra(trip.id);
      const price = extra.promoPrice ?? trip.promoPrice ?? trip.priceFrom;
      return (
        <script type="application/ld+json" set:html={toJsonLd(generateEventSchema({
          name: trip.title,
          startDate: trip.departureDate,
          endDate: trip.returnDate,
          location: dest?.name ?? trip.title,
          price,
          url: `/destino/${dest?.slug}/`,
          image: dest?.heroImage,
        }))} />
      );
    })}
  </Fragment>
  <main>
    <Navbar client:load solid />

    <!-- Hero -->
    <section class="relative flex min-h-[60vh] items-center justify-center overflow-hidden">
      <img
        src={season.heroImage}
        alt={`Viajes en grupo ${season.name} — Travelhood`}
        class="absolute inset-0 h-full w-full object-cover"
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 py-32 text-center">
        <nav class="mb-6 text-sm text-white/70">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span>Temporada</span>
          <span class="mx-2">/</span>
          <span class="text-white font-medium">{season.name}</span>
        </nav>
        <h1 class="font-serif text-3xl font-extrabold text-white sm:text-5xl text-balance leading-tight">
          Viajes en grupo {season.name} 2026 para jóvenes
        </h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">
          {hasTrips
            ? `${seasonTripCards.length} viajes disponibles con coordinador en destino y grupos de 12-18 personas.`
            : "Estamos preparando los viajes para esta temporada. Apúntate para enterarte primero."}
        </p>
      </div>
    </section>

    <!-- Editorial -->
    <section class="bg-background py-16">
      <div class="mx-auto max-w-3xl px-6">
        <p class="text-base leading-relaxed text-muted-foreground whitespace-pre-line">
          {season.editorial}
        </p>
      </div>
    </section>

    {hasTrips ? (
      <>
        <!-- Trips Grid -->
        <section class="bg-card py-16">
          <div class="mx-auto max-w-6xl px-6">
            <div class="mb-10 text-center">
              <span class="text-xs font-bold uppercase tracking-widest text-secondary">
                Viajes {season.name} 2026
              </span>
              <h2 class="mt-3 font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
                {seasonTripCards.length} viajes disponibles en {season.name}
              </h2>
            </div>

            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {seasonTripCards.map((card) => (
                <a
                  href={`/destino/${card.destSlug}`}
                  class="group flex flex-col overflow-hidden rounded-2xl border border-border/40 bg-background transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
                >
                  <div class="relative aspect-[16/10] overflow-hidden">
                    <img
                      src={card.destImage}
                      alt={card.destName}
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent" />
                    {card.isUrgent && (
                      <div class="absolute top-3 left-3">
                        <span class="inline-flex items-center gap-1 rounded-full bg-coral px-2.5 py-1 text-[11px] font-bold text-white shadow-sm">
                          Últimas {card.placesLeft} plazas
                        </span>
                      </div>
                    )}
                    <div class="absolute top-3 right-3">
                      <span class="inline-flex items-center rounded-full bg-black/30 px-2.5 py-1 text-[11px] font-medium text-white backdrop-blur-sm">
                        {card.durationDays} días
                      </span>
                    </div>
                    {card.countryFlag && (
                      <div class="absolute bottom-3 left-3">
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-white/20 px-2.5 py-1 text-[11px] font-medium text-white backdrop-blur-sm">
                          <img
                            src={`https://flagcdn.com/16x12/${card.countryFlag}.png`}
                            alt={card.countryName}
                            class="h-3 w-4 rounded-sm object-cover"
                          />
                          {card.countryName}
                        </span>
                      </div>
                    )}
                  </div>
                  <div class="flex flex-1 flex-col p-4">
                    <h3 class="font-serif text-lg font-bold text-foreground leading-tight group-hover:text-teal-vivid transition-colors">
                      {card.destName}
                    </h3>
                    <p class="mt-1 text-[13px] text-muted-foreground">
                      {card.dateFormatted}
                    </p>
                    <div class="mt-auto pt-4 flex items-end justify-between border-t border-border/30 mt-3">
                      <div>
                        <div class="flex items-baseline gap-1.5">
                          <p class="text-xl font-extrabold text-foreground">
                            {card.price}<span class="text-sm font-semibold text-muted-foreground"> €</span>
                          </p>
                          {card.hasDiscount && (
                            <span class="text-sm text-muted-foreground line-through">{card.originalPrice}€</span>
                          )}
                        </div>
                        {card.promoLabel && (
                          <span class="rounded-full bg-coral/10 px-2 py-0.5 text-[10px] font-bold text-coral">
                            {card.promoLabel}
                          </span>
                        )}
                      </div>
                      <div class="text-right">
                        <p class="text-[10px] text-muted-foreground">+ vuelo ~{card.flightEstimate}€</p>
                        <span class="inline-flex items-center gap-1 rounded-full bg-teal-deep/8 px-2.5 py-1 text-[11px] font-semibold text-teal-deep transition-colors group-hover:bg-coral group-hover:text-white">
                          Ver viaje
                        </span>
                      </div>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>

        <!-- Dates Table -->
        <section class="bg-background py-14">
          <div class="mx-auto max-w-4xl px-6">
            <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
              Fechas y precios — {season.name} 2026
            </h2>
            <div class="overflow-x-auto rounded-xl border border-border/40">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-teal-deep/5">
                    <th class="px-6 py-3 text-left font-bold text-foreground">Destino</th>
                    <th class="px-6 py-3 text-left font-bold text-foreground">Fechas</th>
                    <th class="px-6 py-3 text-left font-bold text-foreground">Días</th>
                    <th class="px-6 py-3 text-left font-bold text-foreground">Precio</th>
                    <th class="px-6 py-3 text-left font-bold text-foreground">Plazas</th>
                  </tr>
                </thead>
                <tbody>
                  {seasonTripCards.map((card) => (
                    <tr class="border-t border-border/30 hover:bg-muted/30 transition-colors">
                      <td class="px-6 py-3">
                        <a href={`/destino/${card.destSlug}`} class="font-semibold text-teal-vivid hover:underline">
                          {card.destName}
                        </a>
                      </td>
                      <td class="px-6 py-3 text-muted-foreground">{card.dateFormatted}</td>
                      <td class="px-6 py-3 text-muted-foreground">{card.durationDays}</td>
                      <td class="px-6 py-3">
                        <span class="font-bold text-foreground">{card.price}€</span>
                        {card.hasDiscount && (
                          <span class="ml-1 text-xs text-muted-foreground line-through">{card.originalPrice}€</span>
                        )}
                      </td>
                      <td class="px-6 py-3">
                        {card.isUrgent ? (
                          <span class="text-coral font-semibold">Últimas {card.placesLeft}</span>
                        ) : (
                          <span class="text-muted-foreground">{card.placesLeft} disponibles</span>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </section>
      </>
    ) : (
      <!-- No trips: lead capture -->
      <section class="py-4">
        <LeadMagnet client:load />
      </section>
    )}

    <GEODataBlock
      title={`Viajes ${season.name} — Datos clave`}
      subtitle={`Información actualizada sobre viajes en grupo en ${season.name} con Travelhood`}
      dataPoints={[
        { label: "Viajes disponibles", value: `${seasonTrips.length} viajes` },
        { label: "Rango de precios", value: seasonTripCards.length > 0 ? `Desde ${Math.min(...seasonTripCards.map(t => t.price))}€` : "Próximamente" },
        { label: "Destinos", value: `${uniqueDestinations.length} destinos` },
        { label: "Grupo medio", value: "14 personas de 20 a 35 años" },
        { label: "Incluye", value: "Coordinador + alojamiento + seguro" },
      ]}
    />

    <!-- FAQ -->
    {season.faqs.length > 0 && (
      <section class="bg-card py-14">
        <div class="mx-auto max-w-3xl px-6">
          <div class="mb-10 text-center">
            <span class="text-xs font-bold uppercase tracking-widest text-secondary">
              Preguntas frecuentes
            </span>
            <h2 class="mt-3 font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
              Sobre viajes en {season.name}
            </h2>
          </div>
          <ContinentFAQ client:load faqs={season.faqs} />
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="bg-teal-deep py-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="font-serif text-2xl font-extrabold text-white sm:text-3xl text-balance">
          {hasTrips
            ? `Las plazas para ${season.name} 2026 se están agotando`
            : `¿Quieres viajar en ${season.name} 2026?`}
        </h2>
        <p class="mt-4 text-white/70 max-w-lg mx-auto">
          {hasTrips
            ? "No te quedes sin tu viaje. Reserva ahora y asegura tu plaza."
            : "Apúntate a la lista de espera y serás el primero en enterarte cuando abramos plazas."}
        </p>
        <a
          href="/viajes/"
          class="mt-8 inline-flex items-center gap-2 rounded-full bg-coral px-8 py-4 text-base font-bold text-white transition-all hover:bg-coral/90 hover:shadow-lg"
        >
          {hasTrips ? "Ver viajes disponibles" : "Ver todos los viajes"}
        </a>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
