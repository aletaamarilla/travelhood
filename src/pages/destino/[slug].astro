---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import TripDetailPage from "@/components/TripDetailPage";
import GEODataBlock from "@/components/GEODataBlock.astro";
import Footer from "@/components/Footer.astro";
import {
  getSearchableDestinations,
  getDestinationBySlug,
  getTripsByDestination,
  getTrips,
  getTestimonialsByDestination,
  getCoordinators,
  getCountries,
  getContinents,
  getSeasons,
  getDestinationSanityFaqs,
  getComparisons,
  getSiteSettings,
  getGlobalFaqs,
} from "@/lib/data-provider";
import { getRelatedDestinations } from "@/lib/related-destinations";
import { FALLBACK_WHATSAPP_PHONE, FALLBACK_WA_COMMUNITY_URL, SITE_URL, buildWhatsAppUrl } from "@/lib/config";
import { resolvePrice } from "@/lib/utils";
import { selectVisibleReviews } from "@/lib/reviews";
import { generateTouristDestinationSchema, generateFaqSchema, generateBreadcrumbSchema, generateEventSchema, toJsonLd } from "@/lib/schemas";

export async function getStaticPaths() {
  const searchableDestinations = await getSearchableDestinations();
  return searchableDestinations.map((d) => ({
    params: { slug: d.slug },
  }));
}

const { slug } = Astro.params;
const [destination, tripsRaw, testimonials, coordinators, countries, continents, seasons, siteSettings] = await Promise.all([
  getDestinationBySlug(slug!),
  getTripsByDestination(slug!),
  getTestimonialsByDestination(slug!),
  getCoordinators(),
  getCountries(),
  getContinents(),
  getSeasons(),
  getSiteSettings(),
]);

const waPhone = siteSettings?.whatsappPhone ?? FALLBACK_WHATSAPP_PHONE;
const waCommunityUrl = siteSettings?.whatsappCommunityUrl ?? FALLBACK_WA_COMMUNITY_URL;
const depositAmount = siteSettings?.depositAmount ?? 250;

if (!destination) return Astro.redirect("/404/");

const country = countries.find((c) => c.id === destination.countryId)!;
const continent = continents.find((c) => c.id === destination.continentId)!;
const privateTripWhatsappMessage = `Hola, somos un grupo y nos gustaría montar un viaje privado a ${destination.name}. ¿Nos contáis cómo funciona?`;
const privateTripWhatsappUrl = buildWhatsAppUrl(waPhone, privateTripWhatsappMessage);

const now = new Date();
const allFutureTrips = tripsRaw
  .filter((t) => new Date(t.departureDate) > now)
  .sort(
    (a, b) =>
      new Date(a.departureDate).getTime() - new Date(b.departureDate).getTime()
  )
  .map((t) => ({
    ...t,
    itinerary: t.itinerary.map((d) => ({
      ...d,
      lat: d.lat ?? destination.coordinates?.lat ?? 0,
      lng: d.lng ?? destination.coordinates?.lng ?? 0,
    })),
  }));
const availableTrips = allFutureTrips.filter((t) => t.status !== "full");

const destTestimonials = selectVisibleReviews(testimonials);
const coordIds = [...new Set(allFutureTrips.map((t) => t.coordinatorId))];
const destCoordinators = coordIds
  .map((id) => coordinators.find((c) => c.id === id))
  .filter(Boolean) as typeof coordinators;

const [faqs, globalFaqBlocks] = await Promise.all([
  getDestinationSanityFaqs(slug!),
  getGlobalFaqs('trip-detail'),
]);
const galleryPhotos = destination.gallery ?? [];
const photos = [
  destination.heroImage,
  ...galleryPhotos.map((photo) => photo.url),
].filter(Boolean);
const photoAlts = [
  destination.heroImageAlt || `Viaje en grupo a ${destination.name}`,
  ...galleryPhotos.map((photo) => photo.alt || `Foto del viaje a ${destination.name}`),
];
const generalFaqs = globalFaqBlocks.flatMap((b) => b.faqs);

const [allComparisons, searchableDestinations, allTripsGlobal] = await Promise.all([
  getComparisons(),
  getSearchableDestinations(),
  getTrips(),
]);
const searchableSlugs = new Set(searchableDestinations.map((d) => d.slug));
const destComparisons = allComparisons.filter((comparison) => {
  if (comparison.slugA !== slug && comparison.slugB !== slug) return false;
  const otherSlug = comparison.slugA === slug ? comparison.slugB : comparison.slugA;
  return searchableSlugs.has(otherSlug);
});
const relatedDestinations = getRelatedDestinations(destination, searchableDestinations, allTripsGlobal, countries);

const destinationPath = `/destino/${destination.slug}/`;
const canonicalUrl = `${SITE_URL}${destinationPath}`;
const seoImage = destination.seo?.ogImage || destination.heroImage;
const pageTitle = destination.seo?.title || `${destination.name} — Viaje en grupo | Travel Hood`;
const pageDescription = destination.seo?.description || `${destination.shortDescription} Viaja en grupo con Travel Hood. Coordinador y alojamiento incluidos.`;
const pageKeywords = destination.seo?.keywords || `viaje en grupo a ${destination.name}, viajes ${country.name}, ${destination.categories.map(c => `viajes de ${c}`).join(', ')}, travel hood, travelhood`;
const seasonLinks = seasons
  .filter((season) => allFutureTrips.some((trip) => trip.tags.some((tag) => season.tags.includes(tag))))
  .map((season) => ({ name: season.name, href: `/temporada/${season.slug}/` }));
const coordinatesLabel = destination.coordinates
  ? `${destination.coordinates.lat.toFixed(4)}, ${destination.coordinates.lng.toFixed(4)}`
  : "";
const climateByMonth = destination.climateByMonth ?? [];
const budgetItems = destination.budgetPerDay ? [
  { label: "Comida sencilla", value: destination.budgetPerDay.mealCostLow },
  { label: "Comida media", value: destination.budgetPerDay.mealCostMid },
  { label: "Cerveza", value: destination.budgetPerDay.beerCost },
  { label: "Gasto diario", value: destination.budgetPerDay.dailyBudget },
  { label: "Extras estimados", value: destination.budgetPerDay.totalExtras },
].filter((item) => item.value) : [];
const hasClimateByMonth = climateByMonth.length > 0;
const hasDestinationDataBlock = hasClimateByMonth || budgetItems.length > 0 || Boolean(coordinatesLabel);
---

<Layout title={pageTitle} description={pageDescription} ogImage={seoImage} heroImage={destination.heroImage} keywords={pageKeywords} canonical={canonicalUrl} ogUrl={canonicalUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:continent.name,url:`/destinos/${continent.slug}/`},{name:destination.name,url:destinationPath}]))} />
    <script type="application/ld+json" set:html={toJsonLd(generateTouristDestinationSchema({name:destination.name,description:destination.description,url:destinationPath,image:seoImage,country:country.name,categories:destination.categories}))} />
    {faqs.length > 0 && <script type="application/ld+json" set:html={toJsonLd(generateFaqSchema(faqs))} />}
    {allFutureTrips.map((trip) => (
      <script type="application/ld+json" set:html={toJsonLd(generateEventSchema({
        name: trip.title,
        description: destination.description,
        startDate: trip.departureDate,
        endDate: trip.returnDate,
        durationDays: trip.durationDays,
        location: destination.name,
        locationAddress: country.name,
        performer: "Travel Hood",
        price: resolvePrice(trip).price,
        url: destinationPath,
        image: seoImage,
        availability: trip.status === "full" ? "https://schema.org/SoldOut" : "https://schema.org/InStock",
        validFrom: trip.departureDate,
        totalPlaces: trip.totalPlaces,
        placesLeft: trip.placesLeft,
      }))} />
    ))}
  </Fragment>
  <main>
    <Navbar solid />
    <TripDetailPage
      client:load
      destination={destination}
      photos={photos}
      photoAlts={photoAlts}
      faqs={faqs}
      generalFaqs={generalFaqs}
      trips={availableTrips}
      allTrips={allFutureTrips}
      testimonials={destTestimonials}
      coordinators={destCoordinators}
      country={country}
      continent={continent}
      pdfUrl={destination.pdfUrl}
      whatsappPhone={waPhone}
      whatsappCommunityUrl={waCommunityUrl}
      depositAmount={depositAmount}
    />

    {hasDestinationDataBlock && (
      <section class="bg-background py-12">
        <div class="mx-auto max-w-5xl px-6">
          <div class="mb-8 max-w-3xl">
            <span class="text-xs font-bold uppercase tracking-widest text-secondary">Datos prácticos</span>
            <h2 class="mt-3 font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
              Clima, presupuesto y ubicación de {destination.name}
            </h2>
            <p class="mt-3 text-base leading-relaxed text-muted-foreground">
              {destination.name} se planifica mejor con una idea clara del clima, los gastos diarios y la ruta. Estos datos te ayudan a preparar el viaje antes de escribirnos por WhatsApp.
            </p>
          </div>

          {hasClimateByMonth && (
            <div class="overflow-hidden rounded-2xl border border-border/40 bg-card shadow-sm">
              <div class="border-b border-border/40 px-4 py-4 sm:px-6">
                <h3 class="font-serif text-lg font-bold text-foreground">Clima por mes</h3>
              </div>
              <div class="overflow-x-auto">
                <table class="min-w-full text-left text-sm">
                  <thead class="bg-teal-deep text-sand">
                    <tr>
                      <th scope="col" class="px-4 py-3 font-bold">Mes</th>
                      <th scope="col" class="px-4 py-3 font-bold">Temperatura</th>
                      <th scope="col" class="px-4 py-3 font-bold">Lluvia</th>
                      <th scope="col" class="px-4 py-3 font-bold">Recomendación</th>
                      <th scope="col" class="px-4 py-3 font-bold">Nota</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-border/40">
                    {climateByMonth.map((month) => (
                      <tr>
                        <th scope="row" class="whitespace-nowrap px-4 py-3 font-bold text-foreground">{month.month}</th>
                        <td class="px-4 py-3 text-muted-foreground">{month.avgTemp || "Consultar"}</td>
                        <td class="px-4 py-3 text-muted-foreground">{month.rainfall || "Consultar"}</td>
                        <td class="px-4 py-3 font-semibold text-foreground">{month.recommendation || "Según fechas"}</td>
                        <td class="px-4 py-3 text-muted-foreground">{month.note || "Sin nota específica"}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          {(budgetItems.length > 0 || coordinatesLabel) && (
            <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {budgetItems.map((item) => (
                <article class="rounded-2xl border border-border/40 bg-card p-5 shadow-sm">
                  <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">{item.label}</p>
                  <p class="mt-2 text-2xl font-extrabold text-foreground">{item.value}</p>
                </article>
              ))}
              {coordinatesLabel && (
                <article class="rounded-2xl border border-border/40 bg-card p-5 shadow-sm">
                  <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Coordenadas</p>
                  <p class="mt-2 text-lg font-extrabold text-foreground">{coordinatesLabel}</p>
                  <p class="mt-2 text-sm text-muted-foreground">Centro de referencia del destino para mapas e itinerario.</p>
                </article>
              )}
            </div>
          )}
        </div>
      </section>
    )}
    <GEODataBlock
      title={`Viaje en grupo a ${destination.name} — Datos clave`}
      subtitle={`Información actualizada sobre viajes organizados a ${destination.name} con Travel Hood`}
      dataPoints={[
        { label: "Precio desde", value: availableTrips.length > 0
          ? `${Math.min(...availableTrips.map(t => resolvePrice(t).price))}€ (sin vuelo)`
          : allFutureTrips.length > 0
            ? `${Math.min(...allFutureTrips.map(t => resolvePrice(t).price))}€ (completo)`
            : "Próximamente" },
        { label: "Duración", value: (availableTrips[0] || allFutureTrips[0]) ? `${(availableTrips[0] || allFutureTrips[0]).durationDays} días` : "Variable" },
        { label: "Plazas por grupo", value: (availableTrips[0] || allFutureTrips[0]) ? `${(availableTrips[0] || allFutureTrips[0]).totalPlaces} personas de 20 a 35 años` : "12 a 13 personas de 20 a 35 años" },
        { label: "Clima", value: destination.climate },
        { label: "País", value: country.name },
        { label: "Tipo de viaje", value: destination.categories.length > 0 ? destination.categories.join(", ") : "Aventura" },
        ...(destination.idealFor ? [{ label: "Ideal para", value: destination.idealFor }] : []),
        { label: "Incluye", value: (availableTrips[0] || allFutureTrips[0])?.included?.length > 0 ? (availableTrips[0] || allFutureTrips[0]).included.slice(0, 3).join(" + ") : "Coordinador + alojamiento + actividades" },
        { label: "Precio cerrado", value: "Sin fondo común ni costes extra en destino" },
      ]}
    />

    <section class="bg-background py-12">
      <div class="mx-auto max-w-5xl px-6">
        <div class="grid gap-5 rounded-3xl border border-border/40 bg-card p-6 shadow-sm sm:p-8 lg:grid-cols-[1fr_auto] lg:items-center">
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-secondary">Formato privado</span>
            <h2 class="mt-3 font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
              ¿Quieres {destination.name} para tu grupo privado?
            </h2>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base">
              Si ya tenéis grupo y queréis viajar juntos, podemos valorar una propuesta privada inspirada en este destino.
            </p>
          </div>
          <a
            href={privateTripWhatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-destination-whatsapp
            data-page="destino"
            data-destination={destination.slug}
            data-cta-location="private_trip_section"
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-teal-deep px-6 py-3 text-sm font-bold text-sand transition-all hover:-translate-y-0.5 hover:shadow-md"
          >
            Pedir {destination.name} para mi grupo
          </a>
        </div>
      </div>
    </section>

    {relatedDestinations.length > 0 && (
      <section class="py-14">
        <div class="mx-auto max-w-5xl px-6">
          <h2 class="font-serif text-xl font-extrabold text-foreground sm:text-2xl mb-2 text-center">
            Destinos similares
          </h2>
          <p class="text-center text-sm text-muted-foreground mb-8">
            Otros viajes que podrían encantarte
          </p>
          <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide sm:grid sm:grid-cols-2 sm:overflow-visible sm:pb-0 lg:grid-cols-3">
            {relatedDestinations.map((rd) => (
              <a href={`/destino/${rd.slug}/`} class="group min-w-[75vw] snap-start rounded-xl overflow-hidden bg-card border border-border shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5 sm:min-w-0">
                {rd.heroImage ? (
                  <img
                    src={rd.heroImage}
                    alt={rd.name}
                    width="400"
                    height="300"
                    loading="lazy"
                    class="aspect-[4/3] w-full object-cover"
                  />
                ) : (
                  <div class="aspect-[4/3] w-full bg-gradient-to-br from-teal-vivid/30 to-coral/20 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-teal-deep/40">
                      <circle cx="12" cy="12" r="10" /><line x1="2" y1="12" x2="22" y2="12" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                    </svg>
                  </div>
                )}
                <div class="p-4">
                  <span class="inline-flex items-center gap-1.5 text-xs text-muted-foreground">
                    {rd.countryFlag && (
                      <img
                        src={`https://flagcdn.com/16x12/${rd.countryFlag.toLowerCase()}.png`}
                        alt={`Bandera de ${rd.countryName}`}
                        width="16"
                        height="12"
                        loading="lazy"
                      />
                    )}
                    {rd.countryName}
                  </span>
                  <h3 class="font-serif text-base font-bold text-foreground group-hover:text-teal-deep transition-colors mt-1">
                    {rd.name}
                  </h3>
                  {rd.priceFrom ? (
                    <p class="text-sm font-semibold text-coral mt-1">Desde {rd.priceFrom.toLocaleString("es-ES")}€</p>
                  ) : (
                    <p class="text-sm text-muted-foreground mt-1">Próximamente</p>
                  )}
                  <span class="text-xs font-semibold text-teal-deep flex items-center gap-1 mt-2">
                    Ver destino <span aria-hidden="true">→</span>
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="bg-card py-14">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="font-serif text-xl font-extrabold text-foreground sm:text-2xl mb-8 text-center">
          Más sobre {destination.name}
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <a href={`/cuando-viajar-a/${destination.slug}/`} class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-teal-deep/10 text-teal-deep">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </span>
            <span class="text-sm font-semibold text-foreground group-hover:text-teal-deep transition-colors">¿Cuándo viajar a {destination.name}?</span>
          </a>
          <a href={`/presupuesto/${destination.slug}/`} class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-coral/10 text-coral">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </span>
            <span class="text-sm font-semibold text-foreground group-hover:text-coral transition-colors">Presupuesto para {destination.name}</span>
          </a>
          <a href={`/pais/${country.slug}/`} class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-yellow-sun/10 text-yellow-sun">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </span>
            <span class="text-sm font-semibold text-foreground group-hover:text-yellow-sun transition-colors">Más viajes en {country.name}</span>
          </a>
          <a href={`/destinos/${continent.slug}/`} class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-teal-deep/10 text-teal-deep">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3z"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
            </span>
            <span class="text-sm font-semibold text-foreground group-hover:text-teal-deep transition-colors">Más destinos en {continent.name}</span>
          </a>
          {destination.categories.map((category) => (
            <a href={`/tipos/${category}/`} class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-coral/10 text-coral">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41 12 22l-8.59-8.59A2 2 0 0 1 3 12V5a2 2 0 0 1 2-2h7a2 2 0 0 1 1.41.59l7.18 7.18a2 2 0 0 1 0 2.82z"/><circle cx="7.5" cy="7.5" r=".5"/></svg>
              </span>
              <span class="text-sm font-semibold capitalize text-foreground group-hover:text-coral transition-colors">Viajes de {category}</span>
            </a>
          ))}
          {seasonLinks.map((season) => (
            <a href={season.href} class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-secondary/10 text-secondary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
              </span>
              <span class="text-sm font-semibold text-foreground group-hover:text-secondary transition-colors">Salidas en {season.name}</span>
            </a>
          ))}
          <a href="/viajes/" class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-teal-vivid/10 text-teal-vivid">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 20a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1"/><path d="M12 2v6"/><path d="m6 8 6-6 6 6"/><path d="M6 14h12"/></svg>
            </span>
            <span class="text-sm font-semibold text-foreground group-hover:text-teal-vivid transition-colors">Ver catálogo de viajes</span>
          </a>
          {destComparisons.map(c => {
            const otherSlug = c.slugA === slug ? c.slugB : c.slugA;
            const otherDest = searchableDestinations.find(d => d.slug === otherSlug);
            const otherName = otherDest?.name || otherSlug;
            return (
              <a href={`/comparar/${c.slugA}-vs-${c.slugB}/`} class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-secondary/10 text-secondary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                </span>
                <span class="text-sm font-semibold text-foreground group-hover:text-secondary transition-colors">{destination.name} vs {otherName}</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <Footer />
    <script is:inline>
      function hasAnalyticsConsent() {
        try {
          const match = document.cookie.match(/(?:^|; )th_cookie_consent=([^;]*)/);
          if (!match) return false;
          return JSON.parse(decodeURIComponent(match[1])).analytics === true;
        } catch {
          return false;
        }
      }

      document.querySelectorAll("[data-destination-whatsapp]").forEach((link) => {
        link.addEventListener("click", () => {
          if (!hasAnalyticsConsent()) return;
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "destination_whatsapp_click",
            destination_slug: link.getAttribute("data-destination") || window.location.pathname,
            cta_location: link.getAttribute("data-cta-location") || "destination_page",
          });
        });
      });
    </script>
  </main>
</Layout>
