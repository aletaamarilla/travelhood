---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import TripDetailPage from "@/components/TripDetailPage";
import GEODataBlock from "@/components/GEODataBlock.astro";
import Footer from "@/components/Footer.astro";
import {
  getDestinations,
  getDestinationBySlug,
  getTripsByDestination,
  getTrips,
  getTestimonials,
  getCoordinators,
  getCountries,
  getContinents,
  getDestinationGallery,
  getDestinationSanityFaqs,
  getComparisons,
  getSiteSettings,
  getGlobalFaqs,
} from "@/lib/data-provider";
import { getRelatedDestinations } from "@/lib/related-destinations";
import { FALLBACK_WHATSAPP_PHONE, FALLBACK_WA_COMMUNITY_URL } from "@/lib/config";
import { lookupCoords } from "@/lib/destination-details";
import { resolvePrice } from "@/lib/utils";
import { generateTouristDestinationSchema, generateFaqSchema, generateBreadcrumbSchema, generateAggregateRatingSchema, generateEventSchema, toJsonLd } from "@/lib/schemas";

export async function getStaticPaths() {
  const allDestinations = await getDestinations();
  return allDestinations.map((d) => ({
    params: { slug: d.slug },
  }));
}

const { slug } = Astro.params;
const [destination, tripsRaw, testimonials, coordinators, countries, continents, siteSettings] = await Promise.all([
  getDestinationBySlug(slug!),
  getTripsByDestination(slug!),
  getTestimonials(),
  getCoordinators(),
  getCountries(),
  getContinents(),
  getSiteSettings(),
]);

const waPhone = siteSettings?.whatsappPhone ?? FALLBACK_WHATSAPP_PHONE;
const waCommunityUrl = siteSettings?.whatsappCommunityUrl ?? FALLBACK_WA_COMMUNITY_URL;
const depositAmount = siteSettings?.depositAmount ?? 250;

if (!destination) return Astro.redirect("/404/");

const country = countries.find((c) => c.id === destination.countryId)!;
const continent = continents.find((c) => c.id === destination.continentId)!;

const now = new Date();
const allFutureTrips = tripsRaw
  .filter((t) => new Date(t.departureDate) > now)
  .sort(
    (a, b) =>
      new Date(a.departureDate).getTime() - new Date(b.departureDate).getTime()
  )
  .map((t) => ({
    ...t,
    itinerary: t.itinerary.map((d) => {
      const coords = lookupCoords(d.title);
      return { ...d, lat: d.lat ?? coords?.[0] ?? 0, lng: d.lng ?? coords?.[1] ?? 0 };
    }),
  }));
const availableTrips = allFutureTrips.filter((t) => t.status !== "full");

const destTestimonials = testimonials.filter(t => t.destinationId === destination.id);
const coordIds = [...new Set(allFutureTrips.map((t) => t.coordinatorId))];
const destCoordinators = coordIds
  .map((id) => coordinators.find((c) => c.id === id))
  .filter(Boolean) as typeof coordinators;

const [galleryPhotos, faqs, globalFaqBlocks] = await Promise.all([
  getDestinationGallery(slug!),
  getDestinationSanityFaqs(slug!),
  getGlobalFaqs('trip-detail'),
]);
const photos = galleryPhotos.length > 0 ? galleryPhotos : [destination.heroImage];
const generalFaqs = globalFaqBlocks.flatMap((b) => b.faqs);

const [allComparisons, destinations, allTripsGlobal] = await Promise.all([
  getComparisons(),
  getDestinations(),
  getTrips(),
]);
const destComparisons = allComparisons.filter(c => c.slugA === slug || c.slugB === slug);
const relatedDestinations = getRelatedDestinations(destination, destinations, allTripsGlobal, countries);

const pageTitle = `${destination.name} — Viaje en grupo | Travel Hood`;
const pageDescription = `${destination.shortDescription} Viaja en grupo con Travel Hood. Coordinador y alojamiento incluidos.`;
---

<Layout title={pageTitle} description={pageDescription} ogImage={destination.heroImage} heroImage={destination.heroImage} keywords={`viaje en grupo a ${destination.name}, viajes ${country.name}, ${destination.categories.map(c => `viajes de ${c}`).join(', ')}, travel hood, travelhood`}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:continent.name,url:`/destinos/${continent.slug}/`},{name:destination.name,url:`/destino/${destination.slug}/`}]))} />
    <script type="application/ld+json" set:html={toJsonLd({...generateTouristDestinationSchema({name:destination.name,description:destination.description,url:`/destino/${destination.slug}/`,image:destination.heroImage}), ...(destTestimonials.length > 0 ? { aggregateRating: generateAggregateRatingSchema(destTestimonials.length) } : {})})} />
    {faqs.length > 0 && <script type="application/ld+json" set:html={toJsonLd(generateFaqSchema(faqs))} />}
    {allFutureTrips.map((trip) => (
      <script type="application/ld+json" set:html={toJsonLd(generateEventSchema({
        name: trip.title,
        description: destination.description,
        startDate: trip.departureDate,
        endDate: trip.returnDate,
        location: destination.name,
        locationAddress: country.name,
        performer: "Travel Hood",
        price: resolvePrice(trip).price,
        url: `/destino/${destination.slug}/`,
        image: destination.heroImage,
        availability: trip.status === "full" ? "https://schema.org/SoldOut" : "https://schema.org/InStock",
        validFrom: trip.departureDate,
      }))} />
    ))}
  </Fragment>
  <main>
    <Navbar solid />
    <TripDetailPage
      client:load
      destination={destination}
      photos={photos}
      faqs={faqs}
      generalFaqs={generalFaqs}
      trips={availableTrips}
      allTrips={allFutureTrips}
      testimonials={destTestimonials}
      coordinators={destCoordinators}
      country={country}
      continent={continent}
      pdfUrl={destination.pdfUrl}
      whatsappPhone={waPhone}
      whatsappCommunityUrl={waCommunityUrl}
      depositAmount={depositAmount}
    />
    <GEODataBlock
      title={`Viaje en grupo a ${destination.name} — Datos clave`}
      subtitle={`Información actualizada sobre viajes organizados a ${destination.name} con Travel Hood`}
      dataPoints={[
        { label: "Precio desde", value: availableTrips.length > 0
          ? `${Math.min(...availableTrips.map(t => resolvePrice(t).price))}€ (sin vuelo)`
          : allFutureTrips.length > 0
            ? `${Math.min(...allFutureTrips.map(t => resolvePrice(t).price))}€ (completo)`
            : "Próximamente" },
        { label: "Duración", value: (availableTrips[0] || allFutureTrips[0]) ? `${(availableTrips[0] || allFutureTrips[0]).durationDays} días` : "Variable" },
        { label: "Plazas por grupo", value: (availableTrips[0] || allFutureTrips[0]) ? `${(availableTrips[0] || allFutureTrips[0]).totalPlaces} personas de 20 a 35 años` : "14 personas de 20 a 35 años" },
        { label: "Clima", value: destination.climate },
        { label: "País", value: country.name },
        { label: "Tipo de viaje", value: destination.categories.length > 0 ? destination.categories.join(", ") : "Aventura" },
        ...(destination.idealFor ? [{ label: "Ideal para", value: destination.idealFor }] : []),
        { label: "Incluye", value: (availableTrips[0] || allFutureTrips[0])?.included?.length > 0 ? (availableTrips[0] || allFutureTrips[0]).included.slice(0, 3).join(" + ") : "Coordinador + alojamiento + actividades" },
      ]}
    />

    {relatedDestinations.length > 0 && (
      <section class="py-14">
        <div class="mx-auto max-w-5xl px-6">
          <h2 class="font-serif text-xl font-extrabold text-foreground sm:text-2xl mb-2 text-center">
            Destinos similares
          </h2>
          <p class="text-center text-sm text-muted-foreground mb-8">
            Otros viajes que podrían encantarte
          </p>
          <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide sm:grid sm:grid-cols-2 sm:overflow-visible sm:pb-0 lg:grid-cols-3">
            {relatedDestinations.map((rd) => (
              <a href={`/destino/${rd.slug}/`} class="group min-w-[75vw] snap-start rounded-xl overflow-hidden bg-card border border-border shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5 sm:min-w-0">
                {rd.heroImage ? (
                  <img
                    src={rd.heroImage}
                    alt={rd.name}
                    width="400"
                    height="300"
                    loading="lazy"
                    class="aspect-[4/3] w-full object-cover"
                  />
                ) : (
                  <div class="aspect-[4/3] w-full bg-gradient-to-br from-teal-vivid/30 to-coral/20 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-teal-deep/40">
                      <circle cx="12" cy="12" r="10" /><line x1="2" y1="12" x2="22" y2="12" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                    </svg>
                  </div>
                )}
                <div class="p-4">
                  <span class="inline-flex items-center gap-1.5 text-xs text-muted-foreground">
                    {rd.countryFlag && (
                      <img
                        src={`https://flagcdn.com/16x12/${rd.countryFlag.toLowerCase()}.png`}
                        alt={`Bandera de ${rd.countryName}`}
                        width="16"
                        height="12"
                        loading="lazy"
                      />
                    )}
                    {rd.countryName}
                  </span>
                  <h3 class="font-serif text-base font-bold text-foreground group-hover:text-teal-deep transition-colors mt-1">
                    {rd.name}
                  </h3>
                  {rd.priceFrom ? (
                    <p class="text-sm font-semibold text-coral mt-1">Desde {rd.priceFrom.toLocaleString("es-ES")}€</p>
                  ) : (
                    <p class="text-sm text-muted-foreground mt-1">Próximamente</p>
                  )}
                  <span class="text-xs font-semibold text-teal-deep flex items-center gap-1 mt-2">
                    Ver destino <span aria-hidden="true">→</span>
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="bg-card py-14">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="font-serif text-xl font-extrabold text-foreground sm:text-2xl mb-8 text-center">
          Más sobre {destination.name}
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <a href={`/cuando-viajar-a/${destination.slug}/`} class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-teal-deep/10 text-teal-deep">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </span>
            <span class="text-sm font-semibold text-foreground group-hover:text-teal-deep transition-colors">¿Cuándo viajar a {destination.name}?</span>
          </a>
          <a href={`/presupuesto/${destination.slug}/`} class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-coral/10 text-coral">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </span>
            <span class="text-sm font-semibold text-foreground group-hover:text-coral transition-colors">Presupuesto para {destination.name}</span>
          </a>
          <a href={`/pais/${country.slug}/`} class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-yellow-sun/10 text-yellow-sun">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </span>
            <span class="text-sm font-semibold text-foreground group-hover:text-yellow-sun transition-colors">Más viajes en {country.name}</span>
          </a>
          {destComparisons.map(c => {
            const otherSlug = c.slugA === slug ? c.slugB : c.slugA;
            const otherDest = destinations.find(d => d.slug === otherSlug);
            const otherName = otherDest?.name || otherSlug;
            return (
              <a href={`/comparar/${c.slugA}-vs-${c.slugB}/`} class="group flex items-center gap-3 rounded-xl bg-background p-4 transition-all hover:shadow-md hover:-translate-y-0.5">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-secondary/10 text-secondary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                </span>
                <span class="text-sm font-semibold text-foreground group-hover:text-secondary transition-colors">{destination.name} vs {otherName}</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
