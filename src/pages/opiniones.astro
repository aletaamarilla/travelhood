---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import GEODataBlock from "@/components/GEODataBlock.astro";
import ReviewCard from "@/components/ReviewCard.astro";
import { getTestimonials, getDestinations, getSiteSettings, resolveSettingsImages } from "@/lib/data-provider";
import { filterVisibleReviews, getTrustpilotProfileLink, sortReviews } from "@/lib/reviews";
import { generateTravelAgencySchema, generateBreadcrumbSchema, toJsonLd } from "@/lib/schemas";

const [testimonials, destinations, settings] = await Promise.all([getTestimonials(), getDestinations(), getSiteSettings()]);
const images = settings ? resolveSettingsImages(settings) : null;
const visibleTestimonials = sortReviews(filterVisibleReviews(testimonials));
const selectedTestimonials = visibleTestimonials.slice(0, 9);
const destinationsById = new Map(destinations.map((destination) => [destination.id, destination]));
const reviewCount = visibleTestimonials.length;
const trustpilotProfileHref = getTrustpilotProfileLink(settings?.trustpilotProfileUrl);
const trustpilotCtaLabel = settings?.reviewsCtaLabel?.trim() || "Ver opiniones en Trustpilot";
const reviewDataPointValue =
  reviewCount === 0
    ? "En revisión"
    : reviewCount === 1
      ? "1 reseña"
      : `${reviewCount} reseñas`;

const agencySchema = generateTravelAgencySchema(undefined, {
  type: settings?.legalLicenseType,
  number: settings?.legalLicenseNumber,
});

const pageTitle = "Opiniones de Travel Hood — Lo que dicen nuestros viajeros";
const pageDescription = "Lee opiniones reales de viajeros que ya han vivido una aventura Travel Hood y descubre cómo es viajar en grupo con nosotros.";
---

<Layout title={pageTitle} description={pageDescription} heroImage={images?.opiniones_heroImage || ''} ogImage={images?.opiniones_heroImage || undefined} keywords="travel hood opiniones, travelhood opiniones, opiniones travel hood, opiniones travelhood, reseñas travel hood, reseñas travelhood, viajes en grupo opiniones, travel hood reviews, travelhood reviews">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(agencySchema)} />
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:"Opiniones",url:"/opiniones/"}]))} />
  </Fragment>
  <main>
    <Navbar solid />

    <section class={`relative flex min-h-[50vh] items-center justify-center overflow-hidden ${!images?.opiniones_heroImage ? 'bg-teal-deep' : ''}`}>
      {images?.opiniones_heroImage && <img src={images.opiniones_heroImage} alt={images.opiniones_heroImageAlt || "Viajeros de Travel Hood compartiendo experiencias"} class="absolute inset-0 h-full w-full object-cover" width="1920" height="1080" loading="eager" fetchpriority="high" />}
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 py-28 text-center">
        <nav class="mb-6 text-sm text-white/70">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span class="text-white font-medium">Opiniones</span>
        </nav>
        <h1 class="font-serif text-3xl font-extrabold text-white sm:text-5xl text-balance leading-tight">
          Opiniones de viajeros Travel Hood
        </h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">
          Historias reales de personas que se atrevieron a viajar en grupo, conocer gente nueva y vivir una aventura diferente.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          {trustpilotProfileHref && (
            <a
              href={trustpilotProfileHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-full bg-coral px-6 py-3 text-sm font-bold text-white transition-all hover:brightness-110"
            >
              {trustpilotCtaLabel}
            </a>
          )}
          <a
            href="#resenas"
            class="inline-flex items-center justify-center rounded-full border border-white/30 px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-white/10"
          >
            Ver opiniones
          </a>
        </div>
      </div>
    </section>

    <section class="bg-background py-16">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
          <div>
            <span class="inline-block rounded-full bg-coral/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-coral">
              Viajes con historias reales
            </span>
            <h2 class="mt-4 font-serif text-2xl font-extrabold text-foreground sm:text-3xl text-balance">
              Lo mejor de Travel Hood lo cuentan quienes ya viajaron
            </h2>
            <p class="mt-4 text-base leading-relaxed text-muted-foreground">
              Cada opinión habla de una experiencia concreta: el grupo, el coordinador, el destino y ese momento en el que viajar sin conocer a nadie deja de dar vértigo.
            </p>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              {trustpilotProfileHref ? (
                <a
                  href={trustpilotProfileHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center rounded-full bg-coral px-6 py-3 text-sm font-bold text-white transition-all hover:brightness-110"
                >
                  {trustpilotCtaLabel}
                </a>
              ) : null}
              <a
                href="/viajes/"
                class="inline-flex items-center justify-center rounded-full border border-teal-deep/20 px-6 py-3 text-sm font-bold text-teal-deep transition-colors hover:border-teal-deep/40 hover:bg-teal-deep/5"
              >
                Ver viajes disponibles
              </a>
            </div>
          </div>

          {trustpilotProfileHref && (
            <div class="rounded-3xl border border-border/70 bg-card p-6 shadow-sm">
              <p class="text-xs font-bold uppercase tracking-widest text-coral">
                También en Trustpilot
              </p>
              <h3 class="mt-3 font-serif text-2xl font-extrabold text-foreground">
                Opiniones que puedes leer fuera de nuestra web
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                Si quieres ver más experiencias, puedes consultar nuestro perfil público de Trustpilot y seguir leyendo allí.
              </p>
              <a
                href={trustpilotProfileHref}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-5 inline-flex items-center justify-center rounded-full border border-teal-deep/20 px-6 py-3 text-sm font-bold text-teal-deep transition-colors hover:border-teal-deep/40 hover:bg-teal-deep/5"
              >
                {trustpilotCtaLabel}
              </a>
            </div>
          )}
        </div>
      </div>
    </section>

    <section id="resenas" class="bg-sand/40 py-16">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-10 max-w-3xl">
          <span class="inline-block rounded-full bg-teal-deep/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-teal-deep">
            Selección de reseñas
          </span>
          <h2 class="mt-4 font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
            Palabras de viajeros como tú
          </h2>
          <p class="mt-3 text-muted-foreground">
            Opiniones sobre lo que de verdad importa: cómo se vive el grupo, cómo se siente viajar sola y qué hace especial cada destino.
          </p>
        </div>

        {selectedTestimonials.length > 0 ? (
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {selectedTestimonials.map((t) => {
              const dest = t.destinationId ? destinationsById.get(t.destinationId) : undefined;
              const fallbackHref = t.sourceProfileUrl || trustpilotProfileHref;

              return (
                <ReviewCard
                  review={t}
                  destinationName={dest?.name}
                  destinationPrefix="Viajó a"
                  ctaFallbackHref={fallbackHref}
                />
              );
            })}
          </div>
        ) : (
          <div class="rounded-3xl border border-border/70 bg-card p-8 text-center shadow-sm">
            <h3 class="font-serif text-2xl font-extrabold text-foreground">
              Pronto compartiremos más experiencias
            </h3>
            <p class="mx-auto mt-3 max-w-2xl text-muted-foreground">
              Estamos preparando nuevas opiniones de viajeros para esta sección.
            </p>
            {trustpilotProfileHref && (
              <a
                href={trustpilotProfileHref}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-flex items-center justify-center rounded-full bg-coral px-6 py-3 text-sm font-bold text-white transition-all hover:brightness-110"
              >
                {trustpilotCtaLabel}
              </a>
            )}
          </div>
        )}
      </div>
    </section>

    <GEODataBlock
      title="Travel Hood en datos"
      subtitle="Contexto operativo de nuestros viajes en grupo"
      dataPoints={[
        { label: "Reseñas publicadas", value: reviewDataPointValue },
        { label: "Grupo", value: "12-13 personas" },
        { label: "Reservan solos", value: "La mayoría" },
        { label: "Rango de edad", value: "20-35 años" },
        { label: "Precio cerrado", value: "Sin fondo común ni costes extra" },
      ]}
    />

    <section class="bg-teal-deep py-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="font-serif text-2xl font-extrabold text-white sm:text-3xl text-balance">
          ¿Listo para vivir tu propia experiencia?
        </h2>
        <p class="mt-4 text-white/70">Únete a la comunidad de viajeros que ya han descubierto otra forma de viajar.</p>
        <a href="/viajes/" class="mt-8 inline-flex items-center gap-2 rounded-full bg-coral px-8 py-4 text-base font-bold text-white transition-all hover:bg-coral/90">
          Ver viajes disponibles
        </a>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
