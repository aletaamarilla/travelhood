---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import GEODataBlock from "@/components/GEODataBlock.astro";
import { getTestimonials, getDestinations, getSiteSettings, resolveSettingsImages } from "@/lib/data-provider";
const [testimonials, destinations, settings] = await Promise.all([getTestimonials(), getDestinations(), getSiteSettings()]);
const images = settings ? resolveSettingsImages(settings) : null;
import { generateTravelAgencySchema, generateBreadcrumbSchema, toJsonLd } from "@/lib/schemas";

const reviewCount = testimonials.length;

const agencySchema = generateTravelAgencySchema();

const pageTitle = "Opiniones de Travel Hood — Lo que dicen nuestros viajeros";
const pageDescription = `Lee las opiniones de viajeros de Travel Hood. Descubre lo que dicen sobre la experiencia de viajar en grupo con nosotros.`;
---

<Layout title={pageTitle} description={pageDescription} heroImage={images?.opiniones_heroImage || ''} ogImage={images?.opiniones_heroImage || undefined} keywords="travel hood opiniones, travelhood opiniones, opiniones travel hood, opiniones travelhood, reseñas travel hood, reseñas travelhood, viajes en grupo opiniones, travel hood reviews, travelhood reviews">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(agencySchema)} />
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:"Opiniones",url:"/opiniones/"}]))} />
  </Fragment>
  <main>
    <Navbar solid />

    <section class={`relative flex min-h-[50vh] items-center justify-center overflow-hidden ${!images?.opiniones_heroImage ? 'bg-teal-deep' : ''}`}>
      {images?.opiniones_heroImage && <img src={images.opiniones_heroImage} alt={images.opiniones_heroImageAlt || "Viajeros de Travel Hood compartiendo experiencias"} class="absolute inset-0 h-full w-full object-cover" width="1920" height="1080" loading="eager" fetchpriority="high" />}
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 py-28 text-center">
        <nav class="mb-6 text-sm text-white/70">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span class="text-white font-medium">Opiniones</span>
        </nav>
        <h1 class="font-serif text-3xl font-extrabold text-white sm:text-5xl text-balance leading-tight">
          Opiniones de Travel Hood — Lo que dicen nuestros viajeros
        </h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">
          Descubre lo que dicen nuestros viajeros sobre la experiencia Travel Hood.
        </p>
      </div>
    </section>

    <section class="bg-background py-16">
      <div class="mx-auto max-w-5xl px-6">
        <div class="mb-12 text-center">
          <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
            Lo que dicen nuestros viajeros
          </h2>
          <p class="mt-3 text-muted-foreground max-w-xl mx-auto">
            Opiniones de viajeros que han vivido la experiencia Travel Hood.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {testimonials.map((t) => {
            const dest = destinations.find((d) => d.id === t.destinationId);
            return (
              <div class="flex flex-col rounded-2xl border border-border/40 bg-card p-6 shadow-sm hover:shadow-md transition-shadow">
                <div class="mb-3 flex items-center gap-1">
                  {Array.from({ length: t.rating }).map(() => (
                    <svg class="h-4 w-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                  ))}
                </div>
                <blockquote class="flex-1 text-base italic text-foreground leading-relaxed">
                  "{t.quote}"
                </blockquote>
                <div class="mt-4 border-t border-border/30 pt-4">
                  <p class="text-sm font-bold text-foreground">{t.name}, {t.age} años</p>
                  <p class="text-xs text-muted-foreground">{t.city}{dest ? ` · Viajó a ${dest.name}` : ""}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <GEODataBlock
      title="Travel Hood en números"
      subtitle="Datos sobre nuestros viajes en grupo"
      dataPoints={[
        { label: "Opiniones", value: `${reviewCount} viajeros` },
        { label: "Grupo", value: "12-13 personas" },
        { label: "Reservan solos", value: "La mayoría" },
        { label: "Rango de edad", value: "20-35 años" },
        { label: "Precio cerrado", value: "Sin fondo común ni costes extra" },
      ]}
    />

    <section class="bg-teal-deep py-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="font-serif text-2xl font-extrabold text-white sm:text-3xl text-balance">
          ¿Listo para vivir tu propia experiencia?
        </h2>
        <p class="mt-4 text-white/70">Únete a la comunidad de viajeros que ya han descubierto otra forma de viajar.</p>
        <a href="/viajes/" class="mt-8 inline-flex items-center gap-2 rounded-full bg-coral px-8 py-4 text-base font-bold text-white transition-all hover:bg-coral/90">
          Ver viajes disponibles
        </a>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
