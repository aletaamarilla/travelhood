---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import ContinentFAQ from "@/components/ContinentFAQ";
import ReviewCard from "@/components/ReviewCard.astro";
import { getDestinations, getTestimonials, getCountries, getTrips, getLandingBySlug, resolveImage, calculatePriceRange, getFeaturedDestinations } from "@/lib/data-provider";
import { selectLandingReviews } from "@/lib/reviews";
const [destinations, testimonials, countries, allTrips, landing, featuredDests] = await Promise.all([
  getDestinations(), getTestimonials(), getCountries(), getTrips(), getLandingBySlug("viajar-sola"), getFeaturedDestinations(5)
]);
const priceRange = calculatePriceRange(allTrips);
const heroImageUrl = resolveImage(landing?.heroImage);
import { generateFaqSchema, generateBreadcrumbSchema, toJsonLd } from "@/lib/schemas";

const pageTitle = "Viajar sola sin miedo — Viajes en grupo para jóvenes | Travel Hood";
const pageDescription = "¿No tienes con quién viajar? La mayoría de viajeros de Travel Hood reservan solos. Grupos de 20-35 años con coordinador en destino. Casi todos repiten.";

const recommendedDestinations = featuredDests;

const editorialDestinationIds = new Set(recommendedDestinations.map((destination) => destination.id));
const relevantTestimonials = selectLandingReviews(testimonials, { destinationIds: editorialDestinationIds, limit: 4 });
const destinationsById = new Map(destinations.map((destination) => [destination.id, destination]));

const faqs = [
  { question: "¿Es seguro viajar sola?", answer: "Sí, con las medidas adecuadas y coordinadores experimentados. Viajas con un grupo reducido de 12-13 personas de tu misma edad y un coordinador Travel Hood que se encarga de la logística y la seguridad. Nunca estás realmente sola." },
  { question: "¿Haré amigos de verdad?", answer: "La gran mayoría de viajeros mantiene el grupo de WhatsApp activo meses después y muchos planifican otro viaje juntos. Las experiencias compartidas crean lazos muy fuertes." },
  { question: "¿Y si no conozco a nadie del grupo?", answer: "Esa es la norma, no la excepción. La mayoría de nuestros viajeros reservan solos. El coordinador facilita la integración desde el primer momento y al segundo día ya hay bromas internas." },
  { question: "¿Hay muchas más mujeres que hombres?", answer: "Los grupos suelen estar bastante equilibrados, con una ligera mayoría femenina (55-60%). El rango de edad 20-35 asegura que todos estéis en un momento vital similar." },
  { question: "¿Qué pasa si no me gusta el grupo?", answer: "Hasta ahora no hemos tenido ningún caso de alguien que no conectara con el grupo. La selección por edad y el tipo de viaje hacen que haya mucha afinidad natural." },
  { question: "¿Tengo tiempo para mí?", answer: "Sí. Los itinerarios incluyen tiempo libre para que explores a tu ritmo, te relajes o hagas lo que te apetezca. No es un campamento militar." },
];
---

<Layout title={pageTitle} description={pageDescription} keywords="viajar sola, viajes para mujeres solas, viajes sin acompañante, viajes grupo mujeres, travel hood, travelhood" heroImage={heroImageUrl || ''} ogImage={heroImageUrl || undefined}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateFaqSchema(faqs))} />
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:"Viajar sola",url:"/viajar-sola/"}]))} />
  </Fragment>
  <main>
    <Navbar solid />

    <!-- Hero -->
    <section class={`relative flex min-h-[60vh] items-center justify-center overflow-hidden ${!heroImageUrl ? 'bg-teal-deep' : ''}`}>
      {heroImageUrl && <img
        src={heroImageUrl}
        alt={landing?.heroImageAlt || "Viajera joven disfrutando de un viaje en grupo con Travel Hood — viajar sola segura"}
        class="absolute inset-0 h-full w-full object-cover"
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
      />}
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 py-32 text-center">
        <nav class="mb-6 text-sm text-white/70">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span class="text-white font-medium">Viajar sola</span>
        </nav>
        <h1 class="font-serif text-3xl font-extrabold text-white sm:text-5xl text-balance leading-tight">
          ¿No tienes con quién ir? Nosotros tenemos el grupo.
        </h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">
          La mayoría de los viajeros de Travel Hood reservan solos. Y casi todos repiten.
        </p>
      </div>
    </section>

    <!-- No estás sola -->
    <section class="bg-background py-16">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-6 text-center">
          No estás sola. Solo no has encontrado tu grupo.
        </h2>
        <div class="space-y-4 text-base leading-relaxed text-muted-foreground">
          <p>
            Hay un miedo que no se dice en voz alta: querer viajar pero no tener con quién. No es falta de ganas. No es falta de dinero. Es no tener a alguien que diga "yo me apunto". Y ese miedo paraliza a miles de personas cada año.
          </p>
          <p>
            Según un estudio de Booking.com (Fuente: <a href="https://www.booking.com" class="underline">estudio Booking.com, 2023</a>), el 72% de las mujeres jóvenes en España quieren viajar pero no lo hacen por falta de compañía. No es que no puedan. Es que no se atreven solas. Y lo entendemos.
          </p>
          <p>
            Pero hay una opción que elimina ese miedo: un viaje en grupo con personas de tu misma edad (20-35 años), un itinerario diseñado para vivir experiencias reales y un coordinador que se encarga de todo. Llegas al aeropuerto sin conocer a nadie. A los dos días, no quieres separarte del grupo.
          </p>
          <p>
            Travel Hood organiza viajes en grupo para jóvenes de 20 a 35 años con coordinador en destino y alojamiento incluidos. El grupo medio tiene 12 a 13 personas de 20-35 años. Cada viaje incluye coordinador, alojamiento y transporte interno.{priceRange ? ` Los viajes cuestan entre ${priceRange.minPrice.toLocaleString('es-ES')}€ y ${priceRange.maxPrice.toLocaleString('es-ES')}€, sin vuelo.` : ''}
          </p>
        </div>
      </div>
    </section>

    <!-- Data Points -->
    <section class="bg-teal-deep py-14">
      <div class="mx-auto max-w-4xl px-6">
        <div class="grid gap-8 sm:grid-cols-3 text-center">
          <div>
            <p class="font-serif text-5xl font-extrabold text-white">+1</p>
            <p class="mt-2 text-base text-white/70">solo necesitas tu billete</p>
          </div>
          <div>
            <p class="font-serif text-5xl font-extrabold text-white">12-13</p>
            <p class="mt-2 text-base text-white/70">viajeros por grupo</p>
          </div>
          <div>
            <p class="font-serif text-5xl font-extrabold text-white">20-35</p>
            <p class="mt-2 text-base text-white/70">años, todos de tu edad</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="bg-card py-16">
      <div class="mx-auto max-w-4xl px-6">
        <div class="mb-10 text-center">
          <span class="text-xs font-bold uppercase tracking-widest text-secondary">
            Experiencias
          </span>
          <h2 class="mt-3 font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
            Ellas y ellos ya se lanzaron
          </h2>
        </div>

        {relevantTestimonials.length > 0 ? (
          <div class="grid gap-6 sm:grid-cols-2">
            {relevantTestimonials.map((t) => {
              const dest = t.destinationId ? destinationsById.get(t.destinationId) : undefined;
              return <ReviewCard review={t} destinationName={dest?.name} destinationPrefix="Viajó a" />;
            })}
          </div>
        ) : (
          <div class="rounded-3xl border border-border/70 bg-background p-8 text-center shadow-sm">
            <h3 class="font-serif text-xl font-extrabold text-foreground">
              Estamos revisando las opiniones visibles
            </h3>
            <p class="mx-auto mt-3 max-w-2xl text-sm text-muted-foreground">
              No mostramos tarjetas antiguas o pendientes de revisión editorial. La selección aparecerá aquí cuando tenga origen trazable.
            </p>
          </div>
        )}
        <div class="mt-8 text-center">
          <a href="/opiniones/" class="text-sm font-bold text-teal-vivid transition-colors hover:text-teal-deep">
            Ver todas las opiniones →
          </a>
        </div>
      </div>
    </section>

    <!-- Recommended Destinations -->
    <section class="bg-background py-16">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-10 text-center">
          <span class="text-xs font-bold uppercase tracking-widest text-secondary">
            Para empezar
          </span>
          <h2 class="mt-3 font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
            Destinos perfectos para tu primer viaje solo/a
          </h2>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
          {recommendedDestinations.map((dest) => {
            const country = countries.find((c) => c.id === dest.countryId);
            return (
              <a
                href={`/destino/${dest.slug}/`}
                class="group flex flex-col overflow-hidden rounded-2xl border border-border/40 bg-card transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
              >
                <div class="relative aspect-[4/3] overflow-hidden">
                  <img
                    src={dest.heroImage}
                    alt={dest.name}
                    width="400"
                    height="300"
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent" />
                  <div class="absolute bottom-3 left-3">
                    <h3 class="font-serif text-lg font-bold text-white">{dest.name}</h3>
                    {country && (
                      <p class="text-xs text-white/70 mt-0.5">{country.name}</p>
                    )}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-card py-14">
      <div class="mx-auto max-w-3xl px-6">
        <div class="mb-10 text-center">
          <span class="text-xs font-bold uppercase tracking-widest text-secondary">
            Preguntas frecuentes
          </span>
          <h2 class="mt-3 font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
            Dudas que todos tenemos antes de lanzarnos
          </h2>
        </div>
        <ContinentFAQ client:load faqs={faqs} />
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-teal-deep py-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="font-serif text-2xl font-extrabold text-white sm:text-3xl text-balance">
          Tu primera aventura empieza aquí
        </h2>
        <p class="mt-4 text-white/70 max-w-lg mx-auto">
          No necesitas compañía. No necesitas experiencia. Solo necesitas decidir que este año vas a dejar de pensarlo y vas a vivirlo.
        </p>
        <a
          href="/viajes/"
          class="mt-8 inline-flex items-center gap-2 rounded-full bg-coral px-8 py-4 text-base font-bold text-white transition-all hover:bg-coral/90 hover:shadow-lg"
        >
          Elige tu viaje
        </a>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
