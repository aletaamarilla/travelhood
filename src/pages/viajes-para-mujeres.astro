---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer.astro";
import GEODataBlock from "@/components/GEODataBlock.astro";
import ContinentFAQ from "@/components/ContinentFAQ";
import InternalLinks from "@/components/InternalLinks.astro";
import { getDestinations, getTestimonials, getTrips } from "@/lib/data-provider";
const [destinations, testimonials, trips] = await Promise.all([
  getDestinations(), getTestimonials(), getTrips()
]);
import { generateFaqSchema, generateBreadcrumbSchema, toJsonLd } from "@/lib/schemas";

const recommendedSlugs = ["tailandia", "bali", "grecia", "marruecos", "costa-rica", "japon"];
const recommendedDestinations = recommendedSlugs
  .map((slug) => destinations.find((d) => d.slug === slug)!)
  .filter(Boolean);

const femaleNames = ["Laura", "Ana", "Sara"];
const femaleTestimonials = testimonials.filter((t) => femaleNames.includes(t.name));

const now = new Date();
const upcomingTrips = trips
  .filter((t) => t.status !== "full" && new Date(t.departureDate) > now)
  .sort((a, b) => new Date(a.departureDate).getTime() - new Date(b.departureDate).getTime())
  .slice(0, 6);

const faqs = [
  { question: "¿Es seguro viajar sola como mujer?", answer: "Sí. En Travelhood viajas con un grupo reducido de 12-18 personas y un coordinador que se encarga de la logística y la seguridad. Seleccionamos destinos seguros y alojamientos en zonas bien comunicadas." },
  { question: "¿Cuántas mujeres viajan con Travelhood?", answer: "Aproximadamente el 65% de nuestros viajeros son mujeres. Los grupos suelen estar equilibrados, con una ligera mayoría femenina. El rango de edad 20-35 años asegura afinidad natural." },
  { question: "¿Puedo compartir habitación con otra mujer?", answer: "Sí. Las habitaciones se organizan por género. Si vas sola, compartirás con otra viajera del grupo. Si prefieres habitación individual, consulta disponibilidad." },
  { question: "¿Qué destinos recomendáis para mujeres que viajan solas?", answer: "Tailandia, Bali y Grecia son los más populares entre viajeras solas. Son seguros, asequibles y ofrecen experiencias muy variadas. Marruecos y Costa Rica también son excelentes opciones." },
  { question: "¿Es diferente este viaje de la página 'Viajar sola'?", answer: "Sí. La sección 'Viajar sola' está orientada a resolver dudas emocionales sobre lanzarse a viajar. Esta página se centra en los aspectos prácticos: seguridad, destinos recomendados para mujeres y experiencias de viajeras reales." },
];

const pageTitle = "Viajes para mujeres — Viaja en grupo con total confianza | Travelhood";
const pageDescription = "Viajes en grupo para mujeres de 20-35 años. El 65% de nuestras viajeras reservan solas. Destinos seguros, coordinador en destino y grupos reducidos. Desde 590€.";
---

<Layout title={pageTitle} description={pageDescription} heroImage="/images/hero-zanzibar.jpg" keywords="viajes para mujeres solas, viajes mujeres, viajes grupo mujeres, viajar sola mujer, viajes seguros mujeres">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateFaqSchema(faqs))} />
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:"Viajes para mujeres",url:"/viajes-para-mujeres/"}]))} />
  </Fragment>
  <main>
    <Navbar client:load solid />

    <section class="relative flex min-h-[60vh] items-center justify-center overflow-hidden">
      <img src="/images/hero-zanzibar.jpg" alt="Grupo de mujeres viajeras disfrutando en la playa" class="absolute inset-0 h-full w-full object-cover" width="1920" height="1080" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 py-28 text-center">
        <nav class="mb-6 text-sm text-white/70">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span class="text-white font-medium">Viajes para mujeres</span>
        </nav>
        <h1 class="font-serif text-3xl font-extrabold text-white sm:text-5xl text-balance leading-tight">
          Viajes para mujeres — Viaja en grupo con total confianza
        </h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">
          El 65% de nuestras viajeras reservan solas. Seguridad, compañía y experiencias increíbles en cada destino.
        </p>
      </div>
    </section>

    <section class="bg-background py-16">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-6 text-center">
          ¿Por qué Travelhood es ideal para mujeres que viajan solas?
        </h2>
        <div class="space-y-4 text-base leading-relaxed text-muted-foreground">
          <p>En Travelhood, más del 65% de los viajeros que reservan solos son mujeres. Esto no es casualidad: nuestros viajes están diseñados con la seguridad, la comodidad y la experiencia como prioridades. Grupos reducidos de 12-18 personas, rango de edad 20-35 años y un coordinador en destino que garantiza que todo funcione.</p>
          <p>No necesitas experiencia previa viajando sola. El 70% de nuestras viajeras no habían hecho un viaje en grupo antes. Llegas al aeropuerto, conoces a tu grupo y desde ese momento tienes compañía, plan y un equipo que se encarga de todo lo logístico.</p>
          <p>Los destinos que seleccionamos pasan un filtro de seguridad, accesibilidad y calidad de experiencia. Alojamientos en zonas bien comunicadas, transporte privado entre ciudades y actividades donde siempre vas acompañada del grupo y el coordinador.</p>
        </div>
      </div>
    </section>

    <section class="bg-card py-14">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
          Destinos recomendados para mujeres
        </h2>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {recommendedDestinations.map((d) => (
            <a href={`/destino/${d.slug}/`} class="group overflow-hidden rounded-2xl border border-border/40 bg-background transition-all hover:shadow-lg">
              <div class="relative h-44 overflow-hidden">
                <img src={d.heroImage} alt={`Viaje para mujeres a ${d.name}`} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" width="600" height="400" loading="lazy" />
              </div>
              <div class="p-5">
                <h3 class="font-serif text-lg font-bold text-foreground">{d.name}</h3>
                <p class="mt-1 text-sm text-muted-foreground line-clamp-2">{d.shortDescription}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {femaleTestimonials.length > 0 && (
      <section class="bg-background py-14">
        <div class="mx-auto max-w-4xl px-6">
          <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
            Lo que dicen nuestras viajeras
          </h2>
          <div class="grid gap-6 sm:grid-cols-3">
            {femaleTestimonials.map((t) => {
              const dest = destinations.find((d) => d.id === t.destinationId);
              return (
                <div class="rounded-2xl border border-border/40 bg-card p-6">
                  <div class="mb-3 flex items-center gap-1">
                    {Array.from({ length: t.rating }).map(() => (
                      <svg class="h-4 w-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    ))}
                  </div>
                  <blockquote class="text-base italic text-foreground">"{t.quote}"</blockquote>
                  <p class="mt-3 text-sm font-bold text-foreground">{t.name}, {t.age} años</p>
                  <p class="text-xs text-muted-foreground">{t.city}{dest ? ` · ${dest.name}` : ""}</p>
                </div>
              );
            })}
          </div>
          <div class="mt-6 text-center">
            <a href="/opiniones/" class="text-sm font-medium text-teal-vivid hover:underline">
              Ver todas las opiniones →
            </a>
          </div>
        </div>
      </section>
    )}

    <GEODataBlock
      title="Viajes para mujeres — Datos clave"
      subtitle="Travelhood en cifras para viajeras"
      dataPoints={[
        { label: "Viajeras solas", value: "65% del grupo" },
        { label: "Repetirían", value: "98%" },
        { label: "Rango de edad", value: "20-35 años" },
        { label: "Grupo medio", value: "14 personas" },
        { label: "Desde", value: "590€ sin vuelo" },
      ]}
    />

    <section class="bg-card py-14">
      <div class="mx-auto max-w-3xl px-6">
        <div class="mb-10 text-center">
          <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
            Preguntas frecuentes sobre viajes para mujeres
          </h2>
        </div>
        <ContinentFAQ client:load faqs={faqs} />
      </div>
    </section>

    <section class="bg-background py-14">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <p class="text-sm text-muted-foreground mb-4">¿Buscas la perspectiva emocional de viajar sola?</p>
        <a href="/viajar-sola/" class="text-teal-vivid font-medium hover:underline">
          Lee nuestra guía "Viajar sola sin miedo" →
        </a>
      </div>
    </section>

    <section class="bg-teal-deep py-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="font-serif text-2xl font-extrabold text-white sm:text-3xl text-balance">
          El grupo ya se está formando
        </h2>
        <p class="mt-4 text-white/70">Solo falta tu nombre en la lista.</p>
        <a href="/viajes/" class="mt-8 inline-flex items-center gap-2 rounded-full bg-coral px-8 py-4 text-base font-bold text-white transition-all hover:bg-coral/90">
          Ver viajes disponibles
        </a>
      </div>
    </section>

    <InternalLinks />
    <Footer />
  </main>
</Layout>
