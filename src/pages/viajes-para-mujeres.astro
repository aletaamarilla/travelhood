---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import GEODataBlock from "@/components/GEODataBlock.astro";
import ContinentFAQ from "@/components/ContinentFAQ";
import ReviewCard from "@/components/ReviewCard.astro";
import { getDestinations, getTestimonials, getTrips, getLandingBySlug, resolveImage, calculatePriceRange, getFeaturedDestinations } from "@/lib/data-provider";
import { selectLandingReviews } from "@/lib/reviews";
const [destinations, testimonials, trips, landing, featuredDests] = await Promise.all([
  getDestinations(), getTestimonials(), getTrips(), getLandingBySlug("viajes-para-mujeres"), getFeaturedDestinations(6)
]);
const heroImageUrl = resolveImage(landing?.heroImage);
import { generateFaqSchema, generateBreadcrumbSchema, toJsonLd } from "@/lib/schemas";

const recommendedDestinations = featuredDests;

const editorialDestinationIds = new Set(recommendedDestinations.map((destination) => destination.id));
const womenLandingTestimonials = selectLandingReviews(testimonials, { destinationIds: editorialDestinationIds, limit: 3 });
const destinationsById = new Map(destinations.map((destination) => [destination.id, destination]));

const now = new Date();
const upcomingTrips = trips
  .filter((t) => t.status !== "full" && new Date(t.departureDate) > now)
  .sort((a, b) => new Date(a.departureDate).getTime() - new Date(b.departureDate).getTime())
  .slice(0, 6);

const faqs = [
  { question: "¿Es seguro viajar sola como mujer?", answer: "Sí. En Travel Hood viajas con un grupo reducido de 12-13 personas y un coordinador que se encarga de la logística y la seguridad. Seleccionamos destinos seguros y alojamientos en zonas bien comunicadas." },
  { question: "¿Cuántas mujeres viajan con Travel Hood?", answer: "La mayoría de nuestros viajeros son mujeres. Los grupos suelen estar equilibrados, con una ligera mayoría femenina. El rango de edad 20-35 años asegura afinidad natural." },
  { question: "¿Puedo compartir habitación con otra mujer?", answer: "Sí. Las habitaciones se organizan por género. Si vas sola, compartirás con otra viajera del grupo. Si prefieres habitación individual, consulta disponibilidad." },
  { question: "¿Qué destinos recomendáis para mujeres que viajan solas?", answer: "Tailandia, Bali e Islandia son los más populares entre viajeras solas. Son seguros, asequibles y ofrecen experiencias muy variadas. Egipto y Colombia también son excelentes opciones." },
  { question: "¿Es diferente este viaje de la página 'Viajar sola'?", answer: "Sí. La sección 'Viajar sola' está orientada a resolver dudas emocionales sobre lanzarse a viajar. Esta página se centra en los aspectos prácticos: seguridad, destinos recomendados para mujeres y experiencias de viajeras." },
];

const priceRange = calculatePriceRange(trips);
const pageTitle = "Viajes para mujeres — Viaja en grupo con total confianza | Travel Hood";
const pageDescription = `Viajes en grupo para mujeres de 20-35 años. La mayoría de nuestras viajeras reservan solas. Destinos seguros, coordinador en destino y grupos reducidos.${priceRange ? ` Desde ${priceRange.minPrice.toLocaleString('es-ES')}€.` : ''}`;
---

<Layout title={pageTitle} description={pageDescription} heroImage={heroImageUrl || ''} ogImage={heroImageUrl || undefined} keywords="viajes para mujeres solas, viajes mujeres, viajes grupo mujeres, viajar sola mujer, viajes seguros mujeres">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateFaqSchema(faqs))} />
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:"Viajes para mujeres",url:"/viajes-para-mujeres/"}]))} />
  </Fragment>
  <main>
    <Navbar solid />

    <section class={`relative flex min-h-[60vh] items-center justify-center overflow-hidden ${!heroImageUrl ? 'bg-teal-deep' : ''}`}>
      {heroImageUrl && <img src={heroImageUrl} alt={landing?.heroImageAlt || "Grupo de mujeres viajeras disfrutando en la playa"} class="absolute inset-0 h-full w-full object-cover" width="1920" height="1080" loading="eager" fetchpriority="high" />}
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 py-28 text-center">
        <nav class="mb-6 text-sm text-white/70">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span class="text-white font-medium">Viajes para mujeres</span>
        </nav>
        <h1 class="font-serif text-3xl font-extrabold text-white sm:text-5xl text-balance leading-tight">
          Viajes para mujeres — Viaja en grupo con total confianza
        </h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">
          La mayoría de nuestras viajeras reservan solas. Seguridad, compañía y experiencias increíbles en cada destino.
        </p>
      </div>
    </section>

    <section class="bg-background py-16">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-6 text-center">
          ¿Por qué Travel Hood es ideal para mujeres que viajan solas?
        </h2>
        <div class="space-y-4 text-base leading-relaxed text-muted-foreground">
          <p>En Travel Hood, la mayoría de los viajeros que reservan solos son mujeres. Esto no es casualidad: nuestros viajes están diseñados con la seguridad, la comodidad y la experiencia como prioridades. Grupos reducidos de 12-13 personas, rango de edad 20-35 años y un coordinador en destino que toma todas las medidas para que todo funcione.</p>
          <p>No necesitas experiencia previa viajando sola. Muchas de nuestras viajeras no habían hecho un viaje en grupo antes. Llegas al aeropuerto, conoces a tu grupo y desde ese momento tienes compañía, plan y un equipo que se encarga de todo lo logístico.</p>
          <p>Los destinos que seleccionamos pasan un filtro de seguridad, accesibilidad y calidad de experiencia. Alojamientos en zonas bien comunicadas, transporte privado entre ciudades y actividades donde siempre vas acompañada del grupo y el coordinador.</p>
        </div>
      </div>
    </section>

    <section class="bg-card py-14">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
          Destinos recomendados para mujeres
        </h2>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {recommendedDestinations.map((d) => (
            <a href={`/destino/${d.slug}/`} class="group overflow-hidden rounded-2xl border border-border/40 bg-background transition-all hover:shadow-lg">
              <div class="relative h-44 overflow-hidden">
                <img src={d.heroImage} alt={`Viaje para mujeres a ${d.name}`} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" width="600" height="400" loading="lazy" />
              </div>
              <div class="p-5">
                <h3 class="font-serif text-lg font-bold text-foreground">{d.name}</h3>
                <p class="mt-1 text-sm text-muted-foreground line-clamp-2">{d.shortDescription}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-background py-14">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
          Opiniones de la comunidad Travel Hood
        </h2>
        {womenLandingTestimonials.length > 0 ? (
          <div class="grid gap-6 sm:grid-cols-3">
            {womenLandingTestimonials.map((t) => {
              const dest = t.destinationId ? destinationsById.get(t.destinationId) : undefined;
              return <ReviewCard review={t} destinationName={dest?.name} destinationPrefix="Viajó a" compact />;
            })}
          </div>
        ) : (
          <div class="rounded-3xl border border-border/70 bg-card p-8 text-center shadow-sm">
            <h3 class="font-serif text-xl font-extrabold text-foreground">
              Estamos revisando las opiniones visibles
            </h3>
            <p class="mx-auto mt-3 max-w-2xl text-sm text-muted-foreground">
              No mostramos tarjetas antiguas o pendientes de revisión editorial. La selección aparecerá aquí cuando tenga origen trazable.
            </p>
          </div>
        )}
        <div class="mt-6 text-center">
          <a href="/opiniones/" class="text-sm font-medium text-teal-vivid hover:underline">
            Ver todas las opiniones →
          </a>
        </div>
      </div>
    </section>

    <GEODataBlock
      title="Viajes para mujeres — Datos clave"
      subtitle="Travel Hood en cifras para viajeras"
      dataPoints={[
        { label: "Viajeras solas", value: "Mayoría del grupo" },
        { label: "Satisfacción", value: "Muy alta" },
        { label: "Rango de edad", value: "20-35 años" },
        { label: "Grupo medio", value: "12-13 personas" },
        { label: "Desde", value: priceRange ? `${priceRange.minPrice.toLocaleString('es-ES')}€ sin vuelo` : "Consulta precios" },
        { label: "Precio cerrado", value: "Sin fondo común ni costes extra" },
      ]}
    />

    <section class="bg-card py-14">
      <div class="mx-auto max-w-3xl px-6">
        <div class="mb-10 text-center">
          <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
            Preguntas frecuentes sobre viajes para mujeres
          </h2>
        </div>
        <ContinentFAQ client:load faqs={faqs} />
      </div>
    </section>

    <section class="bg-background py-14">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <p class="text-sm text-muted-foreground mb-4">¿Buscas la perspectiva emocional de viajar sola?</p>
        <a href="/viajar-sola/" class="text-teal-vivid font-medium hover:underline">
          Lee nuestra guía "Viajar sola sin miedo" →
        </a>
      </div>
    </section>

    <section class="bg-teal-deep py-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="font-serif text-2xl font-extrabold text-white sm:text-3xl text-balance">
          El grupo ya se está formando
        </h2>
        <p class="mt-4 text-white/70">Solo falta tu nombre en la lista.</p>
        <a href="/viajes/" class="mt-8 inline-flex items-center gap-2 rounded-full bg-coral px-8 py-4 text-base font-bold text-white transition-all hover:bg-coral/90">
          Ver viajes disponibles
        </a>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
