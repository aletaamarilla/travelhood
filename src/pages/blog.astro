---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar";
import BlogContent from "@/components/BlogContent";
import CTAFooter from "@/components/CTAFooter.astro";
import Footer from "@/components/Footer.astro";
import { getBlogPosts } from "@/lib/data-provider";
const blogPosts = await getBlogPosts();
import { generateBreadcrumbSchema, generateCollectionPageSchema, generateItemListSchema, toJsonLd } from "@/lib/schemas";
---

<Layout
  title="Blog — Travelhood"
  description="Consejos, guías e historias de viajes en grupo para jóvenes de 20 a 35 años. Inspírate para tu próxima aventura."
  keywords="blog viajes grupo, consejos viajar solo, guías viaje jóvenes, historias viajeros, travelhood blog"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:"Blog",url:"/blog/"}]))} />
    <script type="application/ld+json" set:html={toJsonLd(generateCollectionPageSchema({name:"Blog Travelhood",description:"Consejos, guías e historias de viajes en grupo para jóvenes",url:"/blog/"}))} />
    <script type="application/ld+json" set:html={toJsonLd(generateItemListSchema({name:"Artículos del blog",items:blogPosts.map((p,i)=>({name:p.title,url:`/blog/${p.slug}/`,position:i+1}))}))} />
  </Fragment>
  <main>
    <Navbar client:load solid />

    <!-- Hero -->
    <section class="bg-teal-deep pt-28 pb-16">
      <div class="mx-auto max-w-7xl px-6 text-center">
        <span class="inline-block rounded-full bg-coral/15 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-coral">
          Blog
        </span>
        <h1 class="mt-6 font-serif text-4xl font-extrabold text-sand sm:text-5xl text-balance leading-tight">
          Historias, guías y todo
          <br class="hidden sm:block" />
          lo que necesitas para lanzarte.
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-base text-sand/70 leading-relaxed">
          Inspiración real para viajeros reales. Consejos prácticos, destinos increíbles y las mejores historias de nuestra comunidad.
        </p>
      </div>
    </section>

    <BlogContent client:load posts={blogPosts} />

    <!-- Newsletter / Lead Magnet -->
    <section class="bg-background py-16">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <span class="text-xs font-bold uppercase tracking-widest text-secondary">
          No te pierdas nada
        </span>
        <h2 class="mt-4 font-serif text-2xl font-extrabold text-foreground sm:text-3xl text-balance leading-tight">
          Recibe los mejores consejos para tu próximo viaje.
        </h2>
        <p class="mt-3 text-base text-muted-foreground leading-relaxed">
          Cada semana, inspiración directa a tu email. Sin spam, solo contenido que merece la pena.
        </p>
        <form class="mt-8 flex flex-col gap-3 sm:flex-row sm:gap-0">
          <input
            type="email"
            placeholder="tu@email.com"
            class="flex-1 rounded-full border-2 border-border bg-card px-6 py-3.5 text-sm text-foreground placeholder:text-muted-foreground focus:border-coral focus:outline-none sm:rounded-r-none"
          />
          <button
            type="submit"
            class="rounded-full bg-coral px-8 py-3.5 text-sm font-bold text-white transition-all hover:brightness-110 sm:rounded-l-none"
          >
            Suscribirme
          </button>
        </form>
      </div>
    </section>

    <CTAFooter />
    <Footer />
  </main>

  <a
    href="https://wa.me/34600000000?text=Hola!%20Me%20interesa%20saber%20m%C3%A1s%20sobre%20vuestros%20viajes"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Escríbenos por WhatsApp"
    class="fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-lg transition-all hover:scale-110 hover:shadow-xl"
  >
    <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
</Layout>
