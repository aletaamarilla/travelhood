---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer.astro";
import GEODataBlock from "@/components/GEODataBlock.astro";
import HeroSection from "@/components/HeroSection.astro";
import CTASection from "@/components/CTASection.astro";
import FAQWrapper from "@/components/FAQWrapper.astro";
import InternalLinks from "@/components/InternalLinks.astro";
import { getDestinations, getDestinationBySlug, getTripsByDestination, getCountries, getContinents } from "@/lib/data-provider";
import { resolvePrice } from "@/lib/utils";
import { generateFaqSchema, generateBreadcrumbSchema, toJsonLd } from "@/lib/schemas";

export async function getStaticPaths() {
  const allDestinations = await getDestinations();
  return allDestinations.map((d) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const [destination, destTripsRaw, countries, continents] = await Promise.all([
  getDestinationBySlug(slug!),
  getTripsByDestination(slug!),
  getCountries(),
  getContinents(),
]);

if (!destination) return Astro.redirect("/404");

const country = countries.find((c) => c.id === destination.countryId)!;
const continent = continents.find((c) => c.id === destination.continentId)!;

const now = new Date();
const destTrips = destTripsRaw
  .filter((t) => t.status !== "full" && new Date(t.departureDate) > now)
  .sort((a, b) => new Date(a.departureDate).getTime() - new Date(b.departureDate).getTime());

const prices = destTrips.map((t) => resolvePrice(t).price);
const minPrice = prices.length > 0 ? Math.min(...prices) : 0;
const maxPrice = prices.length > 0 ? Math.max(...prices) : 0;

const avgFlightEstimate = destTrips.length > 0
  ? Math.round(destTrips.reduce((acc, t) => acc + t.flightEstimate, 0) / destTrips.length)
  : 0;

const included = destTrips.length > 0 ? destTrips[0].included : [];
const notIncluded = destTrips.length > 0 ? destTrips[0].notIncluded : [];

const faqs = [
  { question: `¿Cuánto cuesta un viaje a ${destination.name} en grupo?`, answer: `Un viaje en grupo a ${destination.name} con Travelhood cuesta desde ${minPrice > 0 ? minPrice + '€' : 'consultar'} por persona, sin incluir vuelos. Incluye alojamiento, transporte, coordinador y seguro.` },
  { question: `¿Cuánto cuestan los vuelos a ${destination.name}?`, answer: `Los vuelos desde España a ${destination.name} cuestan aproximadamente ${avgFlightEstimate > 0 ? avgFlightEstimate + '€' : 'consultar'} ida y vuelta. El precio varía según la temporada y la antelación de la reserva.` },
  { question: `¿Qué incluye el precio del viaje a ${destination.name}?`, answer: `El precio incluye ${included.slice(0, 3).join(', ').toLowerCase()} y más. No incluye ${notIncluded.slice(0, 2).join(' ni ').toLowerCase()}.` },
];

const totalBudget = minPrice > 0 && avgFlightEstimate > 0 ? minPrice + avgFlightEstimate : 0;
const dailyCost = totalBudget > 0 && destTrips.length > 0 ? Math.round(totalBudget / destTrips[0].durationDays) : 0;

const pageTitle = `¿Cuánto cuesta viajar a ${destination.name}? Presupuesto 2026 — Travelhood`;
const pageDescription = `Presupuesto detallado para viajar a ${destination.name} en 2026. Viaje en grupo desde ${minPrice > 0 ? minPrice + '€' : 'consultar'}, vuelos estimados ${avgFlightEstimate > 0 ? avgFlightEstimate + '€' : 'consultar'}. Desglose completo de costes.`;
---

<Layout title={pageTitle} description={pageDescription} heroImage={destination.heroImage} keywords={`cuanto cuesta viajar a ${destination.name}, presupuesto ${destination.name}, precio viaje ${destination.name}, gastos ${destination.name}`}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:destination.name,url:`/destino/${destination.slug}/`},{name:"Presupuesto",url:`/presupuesto/${destination.slug}/`}]))} />
    <script type="application/ld+json" set:html={toJsonLd(generateFaqSchema(faqs))} />
  </Fragment>
  <main>
    <Navbar client:load solid />

    <HeroSection
      image={destination.heroImage}
      imageAlt={`Presupuesto para viajar a ${destination.name}`}
      breadcrumbs={[
        { label: "Home", href: "/" },
        { label: destination.name, href: `/destino/${destination.slug}/` },
        { label: "Presupuesto" },
      ]}
      title={`¿Cuánto cuesta viajar a ${destination.name} en grupo? — Presupuesto 2026`}
      subtitle="Desglose completo de costes para tu viaje en grupo con Travelhood."
    />

    <section class="bg-background py-16">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
          ¿Cuánto necesitas para viajar a {destination.name}?
        </h2>

        <div class="grid gap-4 sm:grid-cols-3 mb-10">
          <div class="rounded-xl border border-border/40 bg-card p-6 text-center">
            <p class="text-sm text-muted-foreground">Viaje en grupo</p>
            <p class="text-3xl font-extrabold text-teal-vivid">{minPrice > 0 ? `${minPrice}€` : "Consultar"}</p>
            <p class="text-xs text-muted-foreground mt-1">por persona, sin vuelo</p>
          </div>
          <div class="rounded-xl border border-border/40 bg-card p-6 text-center">
            <p class="text-sm text-muted-foreground">Vuelo estimado</p>
            <p class="text-3xl font-extrabold text-coral">{avgFlightEstimate > 0 ? `${avgFlightEstimate}€` : "—"}</p>
            <p class="text-xs text-muted-foreground mt-1">ida y vuelta desde España</p>
          </div>
          <div class="rounded-xl border border-border/40 bg-card p-6 text-center">
            <p class="text-sm text-muted-foreground">Presupuesto total</p>
            <p class="text-3xl font-extrabold text-foreground">{totalBudget > 0 ? `~${totalBudget}€` : "Consultar"}</p>
            <p class="text-xs text-muted-foreground mt-1">{dailyCost > 0 ? `~${dailyCost}€/día` : ""}</p>
          </div>
        </div>

        <div class="space-y-4 text-base leading-relaxed text-muted-foreground">
          <p>El precio de un viaje en grupo a {destination.name} con Travelhood parte desde {minPrice > 0 ? `${minPrice}€` : 'consultar'} por persona{maxPrice > minPrice ? `, pudiendo llegar a ${maxPrice}€ según la temporada y duración` : ''}. Este precio no incluye el vuelo internacional, que desde España ronda los {avgFlightEstimate > 0 ? `${avgFlightEstimate}€` : 'consultar'} ida y vuelta.</p>
          <p>El presupuesto total estimado para {destTrips.length > 0 ? `${destTrips[0].durationDays} días` : 'un viaje'} en {destination.name} es de aproximadamente {totalBudget > 0 ? `${totalBudget}€` : 'consultar'}, incluyendo viaje y vuelo. A esto puedes sumar entre 100-300€ para gastos personales (comidas libres, souvenirs, actividades opcionales).</p>
        </div>
      </div>
    </section>

    {included.length > 0 && (
      <section class="bg-card py-14">
        <div class="mx-auto max-w-3xl px-6">
          <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
            ¿Qué incluye y qué no incluye?
          </h2>
          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <h3 class="font-bold text-teal-vivid mb-3">Incluido en el precio</h3>
              <ul class="space-y-2">
                {included.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-muted-foreground">
                    <span class="text-teal-vivid mt-0.5">✓</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <h3 class="font-bold text-coral mb-3">No incluido</h3>
              <ul class="space-y-2">
                {notIncluded.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-muted-foreground">
                    <span class="text-coral mt-0.5">✗</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>
    )}

    {destTrips.length > 0 && (
      <section class="bg-background py-14">
        <div class="mx-auto max-w-4xl px-6">
          <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
            Viajes disponibles a {destination.name} con precios
          </h2>
          <div class="space-y-4">
            {destTrips.map((trip) => {
              const { price, hasDiscount } = resolvePrice(trip);
              return (
                <a href={`/destino/${destination.slug}/`} class="flex items-center justify-between rounded-xl border border-border/40 bg-card p-5 hover:shadow-md transition-all">
                  <div>
                    <p class="font-serif font-bold text-foreground">{trip.title}</p>
                    <p class="text-sm text-muted-foreground">{trip.durationDays} días · {trip.placesLeft} plazas · Vuelo ~{trip.flightEstimate}€</p>
                  </div>
                  <div class="text-right">
                    {hasDiscount && <p class="text-sm text-muted-foreground line-through">{trip.priceFrom}€</p>}
                    <span class="text-lg font-bold text-teal-vivid">{price}€</span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <GEODataBlock
      title={`Presupuesto ${destination.name} — Resumen`}
      subtitle={`Datos clave de coste para viajar a ${destination.name}`}
      dataPoints={[
        { label: "Viaje desde", value: minPrice > 0 ? `${minPrice}€ (sin vuelo)` : "Próximamente" },
        { label: "Vuelo estimado", value: avgFlightEstimate > 0 ? `${avgFlightEstimate}€ ida/vuelta` : "—" },
        { label: "Total estimado", value: totalBudget > 0 ? `~${totalBudget}€` : "Consultar" },
        { label: "Coste por día", value: dailyCost > 0 ? `~${dailyCost}€/día` : "—" },
        { label: "Gastos extra", value: "100-300€ aprox." },
      ]}
    />

    <FAQWrapper
      title={`Preguntas sobre el presupuesto de ${destination.name}`}
      faqs={faqs}
    />

    <CTASection
      title={`¿Listo para viajar a ${destination.name}?`}
      subtitle={`Reserva tu plaza desde ${minPrice > 0 ? `${minPrice}€` : "consultar"}.`}
      ctaText={`Ver viajes a ${destination.name}`}
      ctaHref={`/destino/${destination.slug}/`}
    />

    <InternalLinks />
    <Footer />
  </main>
</Layout>
