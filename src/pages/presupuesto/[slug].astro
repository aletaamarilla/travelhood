---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import GEODataBlock from "@/components/GEODataBlock.astro";
import HeroSection from "@/components/HeroSection.astro";
import CTASection from "@/components/CTASection.astro";
import FAQWrapper from "@/components/FAQWrapper.astro";
import { getDestinations, getDestinationBySlug, getTripsByDestination, getCountries, getContinents, getSiteSettings } from "@/lib/data-provider";
import { FALLBACK_WHATSAPP_PHONE, SITE_URL, buildWhatsAppUrl } from "@/lib/config";
import { resolvePrice } from "@/lib/utils";
import { generateFaqSchema, generateBreadcrumbSchema, toJsonLd } from "@/lib/schemas";

export async function getStaticPaths() {
  const allDestinations = await getDestinations();
  return allDestinations.map((d) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const [destination, destTripsRaw, countries, continents, siteSettings] = await Promise.all([
  getDestinationBySlug(slug!),
  getTripsByDestination(slug!),
  getCountries(),
  getContinents(),
  getSiteSettings(),
]);

if (!destination) return Astro.redirect("/404/");

const country = countries.find((c) => c.id === destination.countryId)!;
const continent = continents.find((c) => c.id === destination.continentId)!;

const now = new Date();
const destTrips = destTripsRaw
  .filter((t) => t.status !== "full" && new Date(t.departureDate) > now)
  .sort((a, b) => new Date(a.departureDate).getTime() - new Date(b.departureDate).getTime());

const prices = destTrips.map((t) => resolvePrice(t).price);
const minPrice = prices.length > 0 ? Math.min(...prices) : 0;
const maxPrice = prices.length > 0 ? Math.max(...prices) : 0;

const avgFlightEstimate = destTrips.length > 0
  ? Math.round(destTrips.reduce((acc, t) => acc + t.flightEstimate, 0) / destTrips.length)
  : 0;

const included = destTrips.length > 0 ? destTrips[0].included : [];
const notIncluded = destTrips.length > 0 ? destTrips[0].notIncluded : [];
const heroAlt = destination.heroImageAlt || `Viaje en grupo a ${destination.name}`;
const waPhone = siteSettings?.whatsappPhone ?? FALLBACK_WHATSAPP_PHONE;
const whatsappMessage = `Hola! Estoy calculando el presupuesto para ${destination.name}. ¿Me contáis precio, vuelo y gastos reales?`;
const whatsappUrl = buildWhatsAppUrl(waPhone, whatsappMessage);
const budgetItems = destination.budgetPerDay ? [
  { label: "Comida sencilla", value: destination.budgetPerDay.mealCostLow, detail: "Para comidas locales o rápidas durante tiempo libre." },
  { label: "Comida media", value: destination.budgetPerDay.mealCostMid, detail: "Restaurante medio sin convertir cada comida en un lujo." },
  { label: "Cerveza", value: destination.budgetPerDay.beerCost, detail: "Referencia útil para ocio y momentos de grupo." },
  { label: "Gasto diario", value: destination.budgetPerDay.dailyBudget, detail: "Margen orientativo de extras por día en destino." },
  { label: "Extras estimados", value: destination.budgetPerDay.totalExtras, detail: "Estimación para todo el viaje, aparte del precio y vuelo." },
].filter((item) => item.value) : [];

const faqs = [
  { question: `¿Cuánto cuesta un viaje a ${destination.name} en grupo?`, answer: `Un viaje en grupo a ${destination.name} con Travel Hood cuesta desde ${minPrice > 0 ? minPrice + '€' : 'consultar'} por persona, sin incluir vuelos. Incluye alojamiento, transporte y coordinador.` },
  { question: `¿Cuánto cuestan los vuelos a ${destination.name}?`, answer: `Los vuelos desde España a ${destination.name} cuestan aproximadamente ${avgFlightEstimate > 0 ? avgFlightEstimate + '€' : 'consultar'} ida y vuelta. El precio varía según la temporada y la antelación de la reserva.` },
  { question: `¿Qué incluye el precio del viaje a ${destination.name}?`, answer: `El precio incluye ${included.slice(0, 3).join(', ').toLowerCase()} y más. No incluye ${notIncluded.slice(0, 2).join(' ni ').toLowerCase()}.` },
];

const totalBudget = minPrice > 0 && avgFlightEstimate > 0 ? minPrice + avgFlightEstimate : 0;
const dailyCost = totalBudget > 0 && destTrips.length > 0 ? Math.round(totalBudget / destTrips[0].durationDays) : 0;
const currentYear = new Date().getFullYear();

const destinationPath = `/destino/${destination.slug}/`;
const pagePath = `/presupuesto/${destination.slug}/`;
const canonicalUrl = `${SITE_URL}${pagePath}`;
const seoImage = destination.seo?.ogImage || destination.heroImage;
const pageTitle = destination.seo?.presupuestoTitle || `¿Cuánto cuesta viajar a ${destination.name}? Presupuesto ${currentYear} — Travel Hood`;
const pageDescription = destination.seo?.presupuestoDescription || `Presupuesto detallado para viajar a ${destination.name} en ${currentYear}. Viaje en grupo desde ${minPrice > 0 ? minPrice + '€' : 'consultar'}, vuelos estimados ${avgFlightEstimate > 0 ? avgFlightEstimate + '€' : 'consultar'}. Desglose completo de costes.`;
const pageKeywords = destination.seo?.keywords || `cuanto cuesta viajar a ${destination.name}, presupuesto ${destination.name}, precio viaje ${destination.name}, gastos ${destination.name}`;
---

<Layout title={pageTitle} description={pageDescription} heroImage={destination.heroImage} ogImage={seoImage} keywords={pageKeywords} canonical={canonicalUrl} ogUrl={canonicalUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:destination.name,url:destinationPath},{name:"Presupuesto",url:pagePath}]))} />
    <script type="application/ld+json" set:html={toJsonLd(generateFaqSchema(faqs))} />
  </Fragment>
  <main>
    <Navbar solid />

    <HeroSection
      image={destination.heroImage}
      imageAlt={heroAlt}
      breadcrumbs={[
        { label: "Home", href: "/" },
        { label: destination.name, href: `/destino/${destination.slug}/` },
        { label: "Presupuesto" },
      ]}
      title={`¿Cuánto cuesta viajar a ${destination.name} en grupo? — Presupuesto ${currentYear}`}
      subtitle="Desglose completo de costes para tu viaje en grupo con Travel Hood."
    />

    <section class="bg-card py-8">
      <div class="mx-auto max-w-4xl px-6">
        <div class="grid gap-5 rounded-3xl border border-border/40 bg-background p-5 shadow-sm sm:grid-cols-[1fr_auto] sm:items-center sm:p-6">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-secondary">Respuesta rápida</p>
            <h2 class="mt-2 font-serif text-xl font-extrabold text-foreground sm:text-2xl">
              Viajar a {destination.name} cuesta desde {minPrice > 0 ? `${minPrice}€` : "consultar"} sin vuelo{avgFlightEstimate > 0 ? `, con vuelo estimado de ${avgFlightEstimate}€` : ""}.
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              {budgetItems.length > 0
                ? `Para gastos en destino, calcula ${destination.budgetPerDay?.dailyBudget} y un extra total aproximado de ${destination.budgetPerDay?.totalExtras}.`
                : "Te damos una estimación clara por WhatsApp según fechas, vuelos y disponibilidad real."}
            </p>
          </div>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-destination-whatsapp
            data-page="presupuesto"
            data-destination={destination.slug}
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-[#25D366] px-6 py-3 text-sm font-extrabold text-white transition-all hover:-translate-y-0.5 hover:brightness-110"
          >
            Resolver dudas por WhatsApp
          </a>
        </div>
      </div>
    </section>

    <section class="bg-background py-16">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
          ¿Cuánto necesitas para viajar a {destination.name}?
        </h2>

        <div class="grid gap-4 sm:grid-cols-3 mb-10">
          <div class="rounded-xl border border-border/40 bg-card p-6 text-center">
            <p class="text-sm text-muted-foreground">Viaje en grupo</p>
            <p class="text-3xl font-extrabold text-teal-vivid">{minPrice > 0 ? `${minPrice}€` : "Consultar"}</p>
            <p class="text-xs text-muted-foreground mt-1">por persona, sin vuelo</p>
          </div>
          <div class="rounded-xl border border-border/40 bg-card p-6 text-center">
            <p class="text-sm text-muted-foreground">Vuelo estimado</p>
            <p class="text-3xl font-extrabold text-coral">{avgFlightEstimate > 0 ? `${avgFlightEstimate}€` : "—"}</p>
            <p class="text-xs text-muted-foreground mt-1">ida y vuelta desde España</p>
          </div>
          <div class="rounded-xl border border-border/40 bg-card p-6 text-center">
            <p class="text-sm text-muted-foreground">Presupuesto total</p>
            <p class="text-3xl font-extrabold text-foreground">{totalBudget > 0 ? `~${totalBudget}€` : "Consultar"}</p>
            <p class="text-xs text-muted-foreground mt-1">{dailyCost > 0 ? `~${dailyCost}€/día` : ""}</p>
          </div>
        </div>

        <div class="space-y-4 text-base leading-relaxed text-muted-foreground">
          <p>El precio de un viaje en grupo a {destination.name} con Travel Hood parte desde {minPrice > 0 ? `${minPrice}€` : 'consultar'} por persona{maxPrice > minPrice ? `, pudiendo llegar a ${maxPrice}€ según la temporada y duración` : ''}. Este precio no incluye el vuelo internacional, que desde España ronda los {avgFlightEstimate > 0 ? `${avgFlightEstimate}€` : 'consultar'} ida y vuelta.</p>
          <p>El presupuesto total estimado para {destTrips.length > 0 ? `${destTrips[0].durationDays} días` : 'un viaje'} en {destination.name} es de aproximadamente {totalBudget > 0 ? `${totalBudget}€` : 'consultar'}, incluyendo viaje y vuelo. A esto puedes sumar entre 100-300€ para gastos personales (comidas libres, souvenirs, actividades opcionales).</p>
        </div>
      </div>
    </section>

    {budgetItems.length > 0 && (
      <section class="bg-card py-14">
        <div class="mx-auto max-w-5xl px-6">
          <h2 class="mb-3 text-center font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
            Gastos diarios en {destination.name}
          </h2>
          <p class="mx-auto mb-8 max-w-2xl text-center text-sm text-muted-foreground">
            Desglose orientativo para que calcules el viaje completo sin sorpresas ni fondo común.
          </p>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {budgetItems.map((item) => (
              <article class="rounded-2xl border border-border/40 bg-background p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">{item.label}</p>
                <p class="mt-2 text-2xl font-extrabold text-foreground">{item.value}</p>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{item.detail}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    {included.length > 0 && (
      <section class="bg-card py-14">
        <div class="mx-auto max-w-3xl px-6">
          <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
            ¿Qué incluye y qué no incluye?
          </h2>
          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <h3 class="font-bold text-teal-vivid mb-3">Incluido en el precio</h3>
              <ul class="space-y-2">
                {included.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-muted-foreground">
                    <span class="text-teal-vivid mt-0.5">✓</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <h3 class="font-bold text-coral mb-3">No incluido</h3>
              <ul class="space-y-2">
                {notIncluded.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-muted-foreground">
                    <span class="text-coral mt-0.5">✗</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>
    )}

    {destTrips.length > 0 && (
      <section class="bg-background py-14">
        <div class="mx-auto max-w-4xl px-6">
          <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
            Viajes disponibles a {destination.name} con precios
          </h2>
          <div class="space-y-4">
            {destTrips.map((trip) => {
              const { price, hasDiscount } = resolvePrice(trip);
              return (
                <a href={`/destino/${destination.slug}/`} class="flex items-center justify-between rounded-xl border border-border/40 bg-card p-5 hover:shadow-md transition-all">
                  <div>
                    <p class="font-serif font-bold text-foreground">{trip.title}</p>
                    <p class="text-sm text-muted-foreground">{trip.durationDays} días · {trip.placesLeft} plazas · Vuelo ~{trip.flightEstimate}€</p>
                  </div>
                  <div class="text-right">
                    {hasDiscount && <p class="text-sm text-muted-foreground line-through">{trip.priceFrom}€</p>}
                    <span class="text-lg font-bold text-teal-vivid">{price}€</span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <GEODataBlock
      title={`Presupuesto ${destination.name} — Resumen`}
      subtitle={`Datos clave de coste para viajar a ${destination.name}`}
      dataPoints={[
        { label: "Viaje desde", value: minPrice > 0 ? `${minPrice}€ (sin vuelo)` : "Próximamente" },
        { label: "Vuelo estimado", value: avgFlightEstimate > 0 ? `${avgFlightEstimate}€ ida/vuelta` : "—" },
        { label: "Total estimado", value: totalBudget > 0 ? `~${totalBudget}€` : "Consultar" },
        { label: "Coste por día", value: dailyCost > 0 ? `~${dailyCost}€/día` : "—" },
        { label: "Gastos extra", value: "100-300€ aprox." },
      ]}
    />

    <FAQWrapper
      title={`Preguntas sobre el presupuesto de ${destination.name}`}
      faqs={faqs}
    />

    <CTASection
      title={`¿Listo para viajar a ${destination.name}?`}
      subtitle={`Te contamos precio, vuelo estimado, fechas y cómo reservar tu plaza desde ${minPrice > 0 ? `${minPrice}€` : "consultar"}.`}
      ctaText="Pedir presupuesto por WhatsApp"
      ctaHref={whatsappUrl}
    />

    <script is:inline define:vars={{ destinationSlug: destination.slug }}>
      function hasAnalyticsConsent() {
        try {
          const match = document.cookie.match(/(?:^|; )th_cookie_consent=([^;]*)/);
          if (!match) return false;
          return JSON.parse(decodeURIComponent(match[1])).analytics === true;
        } catch {
          return false;
        }
      }

      document.querySelectorAll("[data-destination-whatsapp], a[href*='wa.me']").forEach((link) => {
        link.addEventListener("click", () => {
          if (!hasAnalyticsConsent()) return;
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "destination_whatsapp_click",
            destination_slug: link.getAttribute("data-destination") || destinationSlug,
            cta_location: link.getAttribute("data-cta-location") || "presupuesto_bottom_cta",
          });
        });
      });
    </script>

    <Footer />
  </main>
</Layout>
