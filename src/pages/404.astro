---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer.astro";
import { getDestinations, getTrips } from "@/lib/data-provider";
const [destinations, trips] = await Promise.all([getDestinations(), getTrips()]);

const popularSlugs = ["tailandia", "japon", "marruecos", "bali", "grecia", "costa-rica"];
const popularDestinations = destinations
  .filter((d) => popularSlugs.includes(d.slug))
  .map((d) => {
    const destTrips = trips.filter((t) => t.destinationId === d.id && t.status !== "full");
    const minPrice = destTrips.length > 0 ? Math.min(...destTrips.map((t) => t.promoPrice ?? t.priceFrom)) : null;
    return { ...d, minPrice, tripCount: destTrips.length };
  });
---

<Layout
  title="Página no encontrada — Travelhood"
  description="La página que buscas no existe. Descubre viajes en grupo para jóvenes de 20 a 35 años."
  noIndex={true}
>
  <Navbar client:load solid />

  <main class="min-h-[70vh] bg-background">
    <section class="py-20 sm:py-28">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <span class="inline-block text-7xl sm:text-8xl font-serif font-extrabold text-coral/20 mb-4">404</span>
        <h1 class="font-serif text-3xl sm:text-4xl font-extrabold text-foreground mb-4">
          ¡Ups! Esta página se fue de viaje
        </h1>
        <p class="text-lg text-muted-foreground max-w-xl mx-auto mb-10">
          Parece que la página que buscas no existe o ha cambiado de dirección. Pero no te preocupes, tenemos destinos increíbles esperándote.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
          <a
            href="/viajes/"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-coral px-8 py-3.5 text-base font-bold text-white transition-all hover:brightness-110 hover:shadow-lg"
          >
            Ver todos los viajes
          </a>
          <a
            href="/"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-teal-deep px-8 py-3.5 text-base font-bold text-white transition-all hover:brightness-110"
          >
            Volver al inicio
          </a>
        </div>

        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-secondary">
            Destinos populares
          </span>
          <h2 class="mt-3 font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8">
            ¿A dónde te llevamos?
          </h2>

          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {popularDestinations.map((dest) => (
              <a
                href={`/destino/${dest.slug}/`}
                class="group relative overflow-hidden rounded-2xl border border-border/40 bg-card transition-all hover:shadow-lg hover:-translate-y-0.5"
              >
                <div class="aspect-[16/10] overflow-hidden">
                  <img
                    src={dest.heroImage}
                    alt={`Viaje en grupo a ${dest.name}`}
                    width="400"
                    height="250"
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
                <div class="p-4 text-left">
                  <h3 class="font-serif font-bold text-foreground">{dest.name}</h3>
                  <p class="mt-1 text-sm text-muted-foreground line-clamp-2">{dest.shortDescription}</p>
                  {dest.minPrice && (
                    <p class="mt-2 text-sm font-semibold text-teal-vivid">
                      Desde {dest.minPrice}€
                    </p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
