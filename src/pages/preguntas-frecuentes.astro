---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import ContinentFAQ from "@/components/ContinentFAQ";
import { getSiteSettings, resolveSettingsImages, getGlobalFaqs } from "@/lib/data-provider";
import { generateFaqSchema, generateBreadcrumbSchema, toJsonLd } from "@/lib/schemas";

const [faqPageSettings, faqBlocks] = await Promise.all([
  getSiteSettings(),
  getGlobalFaqs('preguntas-frecuentes'),
]);
const faqPageImages = faqPageSettings ? resolveSettingsImages(faqPageSettings) : null;

const pageTitle = "Preguntas frecuentes — Viajes en grupo para jóvenes | Travel Hood";
const pageDescription = "Todas las preguntas sobre viajes en grupo con Travel Hood: reservas, pagos, cancelaciones, el grupo, el coordinador y los seguros. Resolvemos tus dudas.";

const allFaqs = faqBlocks.flatMap((block) => block.faqs);
---

<Layout title={pageTitle} description={pageDescription} keywords="preguntas frecuentes viajes grupo, dudas viaje organizado, cancelación viaje, seguro viaje grupo, travel hood faq, travelhood faq">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateFaqSchema(allFaqs))} />
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:"Preguntas frecuentes",url:"/preguntas-frecuentes/"}]))} />
  </Fragment>
  <main>
    <Navbar solid />

    <!-- Hero -->
    <section class="relative bg-teal-deep py-24">
      {faqPageImages?.faq_heroImage && (
        <img src={faqPageImages.faq_heroImage} alt={faqPageImages.faq_heroImageAlt || ""} aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" width="1920" height="1080" loading="eager" fetchpriority="high" />
      )}
      {faqPageImages?.faq_heroImage && <div class="absolute inset-0 bg-teal-deep/85"></div>}
      <div class="relative mx-auto max-w-4xl px-6 text-center">
        <nav class="mb-6 text-sm text-white/70">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span class="text-white font-medium">Preguntas frecuentes</span>
        </nav>
        <h1 class="font-serif text-3xl font-extrabold text-white sm:text-5xl text-balance leading-tight">
          Preguntas frecuentes
        </h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">
          {allFaqs.length} preguntas con respuestas claras. Sin letra pequeña.
        </p>
      </div>
    </section>

    <!-- FAQ Blocks -->
    {faqBlocks.map((block, blockIdx) => (
      <section class={blockIdx % 2 === 0 ? "bg-background py-14" : "bg-card py-14"}>
        <div class="mx-auto max-w-3xl px-6">
          <h2 class="font-serif text-2xl font-extrabold text-foreground mb-8 text-center">
            {block.title}
          </h2>
          <ContinentFAQ client:load faqs={block.faqs} />
        </div>

        {blockIdx === 1 && (
          <div class="mx-auto max-w-3xl px-6 mt-8 text-center">
            <a
              href="/viajes/"
              class="inline-flex items-center gap-2 rounded-full bg-coral px-6 py-3 text-sm font-bold text-white transition-all hover:bg-coral/90 hover:shadow-lg"
            >
              Ver viajes y precios
            </a>
          </div>
        )}

        {blockIdx === 2 && (
          <div class="mx-auto max-w-3xl px-6 mt-8 text-center">
            <a
              href="/viajar-sola/"
              class="inline-flex items-center gap-2 text-sm font-semibold text-teal-vivid hover:underline"
            >
              Leer más sobre viajar sola →
            </a>
          </div>
        )}
      </section>
    ))}

    <!-- CTA -->
    <section class="bg-teal-deep py-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="font-serif text-2xl font-extrabold text-white sm:text-3xl text-balance">
          ¿Todavía tienes dudas?
        </h2>
        <p class="mt-4 text-white/70 max-w-lg mx-auto">
          Escríbenos y te respondemos en menos de 24 horas. O mejor aún, echa un vistazo a los viajes y decide por ti mismo/a.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/viajes/"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-coral px-8 py-4 text-base font-bold text-white transition-all hover:bg-coral/90 hover:shadow-lg"
          >
            Ver viajes disponibles
          </a>
          <a
            href="/como-funciona/"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-white/10 px-8 py-4 text-base font-bold text-white transition-all hover:bg-white/20"
          >
            Cómo funciona
          </a>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
