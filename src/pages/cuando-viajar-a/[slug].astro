---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer.astro";
import GEODataBlock from "@/components/GEODataBlock.astro";
import HeroSection from "@/components/HeroSection.astro";
import CTASection from "@/components/CTASection.astro";
import FAQWrapper from "@/components/FAQWrapper.astro";
import InternalLinks from "@/components/InternalLinks.astro";
import { getDestinations, getDestinationBySlug, getTripsByDestination, getCountries, getContinents } from "@/lib/data-provider";
import { resolvePrice } from "@/lib/utils";
import { generateFaqSchema, generateBreadcrumbSchema, toJsonLd } from "@/lib/schemas";

export async function getStaticPaths() {
  const allDestinations = await getDestinations();
  return allDestinations.map((d) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const [destination, destTripsRaw, countries, continents] = await Promise.all([
  getDestinationBySlug(slug!),
  getTripsByDestination(slug!),
  getCountries(),
  getContinents(),
]);

if (!destination) return Astro.redirect("/404");

const country = countries.find((c) => c.id === destination.countryId)!;
const continent = continents.find((c) => c.id === destination.continentId)!;

const now = new Date();
const destTrips = destTripsRaw
  .filter((t) => t.status !== "full" && new Date(t.departureDate) > now)
  .sort((a, b) => new Date(a.departureDate).getTime() - new Date(b.departureDate).getTime());

const minPrice = destTrips.length > 0
  ? Math.min(...destTrips.map((t) => resolvePrice(t).price))
  : 0;

const faqs = [
  { question: `¿Cuál es la mejor época para viajar a ${destination.name}?`, answer: `${destination.climate} Consulta las fechas de los viajes disponibles para elegir la temporada que mejor se adapte a tu preferencia.` },
  { question: `¿Cuánto cuesta viajar a ${destination.name} en grupo?`, answer: `Un viaje en grupo a ${destination.name} con Travelhood cuesta desde ${minPrice > 0 ? minPrice + '€' : 'consultar'} por persona, sin incluir vuelos. Incluye alojamiento, transporte, coordinador y seguro.` },
  { question: `¿Cuántos días dura un viaje a ${destination.name}?`, answer: destTrips.length > 0 ? `Los viajes a ${destination.name} duran ${destTrips[0].durationDays} días. Incluyen itinerario completo con actividades y tiempo libre.` : `La duración varía según la temporada. Consulta los viajes disponibles para más detalles.` },
];

const pageTitle = `¿Cuándo es la mejor época para viajar a ${destination.name}? — Travelhood`;
const pageDescription = `Descubre cuándo viajar a ${destination.name}. ${destination.climate} Viajes en grupo desde ${minPrice > 0 ? minPrice + '€' : 'consultar'} con coordinador y alojamiento incluidos.`;
---

<Layout title={pageTitle} description={pageDescription} heroImage={destination.heroImage} keywords={`mejor época viajar ${destination.name}, cuando viajar a ${destination.name}, clima ${destination.name}, temporada ${destination.name}`}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:destination.name,url:`/destino/${destination.slug}/`},{name:"Cuándo viajar",url:`/cuando-viajar-a/${destination.slug}/`}]))} />
    <script type="application/ld+json" set:html={toJsonLd(generateFaqSchema(faqs))} />
  </Fragment>
  <main>
    <Navbar client:load solid />

    <HeroSection
      image={destination.heroImage}
      imageAlt={`Mejor época para viajar a ${destination.name}`}
      breadcrumbs={[
        { label: "Home", href: "/" },
        { label: destination.name, href: `/destino/${destination.slug}/` },
        { label: "Cuándo viajar" },
      ]}
      title={`¿Cuándo es la mejor época para viajar a ${destination.name}?`}
      subtitle={destination.climate}
    />

    <section class="bg-background py-16">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-6 text-center">
          ¿Qué clima encontrarás en {destination.name}?
        </h2>
        <div class="space-y-4 text-base leading-relaxed text-muted-foreground">
          <p>{destination.climate} {destination.name} ofrece experiencias únicas en cada temporada. Travelhood selecciona las mejores fechas para cada destino.</p>
          <p>Un viaje en grupo a {destination.name} con Travelhood cuesta desde {minPrice > 0 ? `${minPrice}€` : 'consultar precio'} por persona, sin incluir vuelos. El precio incluye alojamiento, transporte interno, coordinador y seguro de viaje.</p>
        </div>
      </div>
    </section>

    {destTrips.length > 0 && (
      <section class="bg-card py-14">
        <div class="mx-auto max-w-4xl px-6">
          <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
            Viajes disponibles a {destination.name}
          </h2>
          <div class="space-y-4">
            {destTrips.map((trip) => {
              const { price } = resolvePrice(trip);
              return (
                <a href={`/destino/${destination.slug}/`} class="flex items-center justify-between rounded-xl border border-border/40 bg-background p-5 hover:shadow-md transition-all">
                  <div>
                    <p class="font-serif font-bold text-foreground">{trip.title}</p>
                    <p class="text-sm text-muted-foreground">{trip.durationDays} días · {trip.placesLeft} plazas</p>
                  </div>
                  <span class="text-lg font-bold text-teal-vivid">{price}€</span>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <GEODataBlock
      title={`${destination.name} — Datos de viaje`}
      subtitle={`Información clave para planificar tu viaje a ${destination.name}`}
      dataPoints={[
        { label: "Clima", value: destination.climate },
        { label: "Precio desde", value: minPrice > 0 ? `${minPrice}€ (sin vuelo)` : "Próximamente" },
        { label: "País", value: country.name },
        { label: "Continente", value: continent.name },
        { label: "Grupo medio", value: "14 personas de 20 a 35 años" },
      ]}
    />

    <FAQWrapper
      title={`Preguntas sobre cuándo viajar a ${destination.name}`}
      faqs={faqs}
    />

    <CTASection
      title={`¿Listo para viajar a ${destination.name}?`}
      subtitle="El grupo ya se está formando."
      ctaText={`Ver viajes a ${destination.name}`}
      ctaHref={`/destino/${destination.slug}/`}
    />

    <InternalLinks />
    <Footer />
  </main>
</Layout>
