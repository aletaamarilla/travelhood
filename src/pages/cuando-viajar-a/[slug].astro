---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import GEODataBlock from "@/components/GEODataBlock.astro";
import HeroSection from "@/components/HeroSection.astro";
import CTASection from "@/components/CTASection.astro";
import FAQWrapper from "@/components/FAQWrapper.astro";
import { getDestinations, getDestinationBySlug, getTripsByDestination, getCountries, getContinents, getSiteSettings } from "@/lib/data-provider";
import { FALLBACK_WHATSAPP_PHONE, SITE_URL, buildWhatsAppUrl } from "@/lib/config";
import { resolvePrice } from "@/lib/utils";
import { generateFaqSchema, generateBreadcrumbSchema, toJsonLd } from "@/lib/schemas";

export async function getStaticPaths() {
  const allDestinations = await getDestinations();
  return allDestinations.map((d) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const [destination, destTripsRaw, countries, continents, siteSettings] = await Promise.all([
  getDestinationBySlug(slug!),
  getTripsByDestination(slug!),
  getCountries(),
  getContinents(),
  getSiteSettings(),
]);

if (!destination) return Astro.redirect("/404/");

const country = countries.find((c) => c.id === destination.countryId)!;
const continent = continents.find((c) => c.id === destination.continentId)!;

const now = new Date();
const destTrips = destTripsRaw
  .filter((t) => t.status !== "full" && new Date(t.departureDate) > now)
  .sort((a, b) => new Date(a.departureDate).getTime() - new Date(b.departureDate).getTime());

const minPrice = destTrips.length > 0
  ? Math.min(...destTrips.map((t) => resolvePrice(t).price))
  : 0;
const featuredTrip = destTrips[0];
const heroAlt = destination.heroImageAlt || `Viaje en grupo a ${destination.name}`;
const waPhone = siteSettings?.whatsappPhone ?? FALLBACK_WHATSAPP_PHONE;
const whatsappMessage = `Hola! Estoy mirando cuándo viajar a ${destination.name}. ¿Me contáis qué salida encaja mejor?`;
const whatsappUrl = buildWhatsAppUrl(waPhone, whatsappMessage);
const climateByMonth = destination.climateByMonth ?? [];
const hasClimateByMonth = climateByMonth.length > 0;

const faqs = [
  { question: `¿Cuál es la mejor época para viajar a ${destination.name}?`, answer: `${destination.climate} Consulta las fechas de los viajes disponibles para elegir la temporada que mejor se adapte a tu preferencia.` },
  { question: `¿Cuánto cuesta viajar a ${destination.name} en grupo?`, answer: `Un viaje en grupo a ${destination.name} con Travel Hood cuesta desde ${minPrice > 0 ? minPrice + '€' : 'consultar'} por persona, sin incluir vuelos. Incluye alojamiento, transporte y coordinador.` },
  { question: `¿Cuántos días dura un viaje a ${destination.name}?`, answer: destTrips.length > 0 ? `Los viajes a ${destination.name} duran ${destTrips[0].durationDays} días. Incluyen itinerario completo con actividades y tiempo libre.` : `La duración varía según la temporada. Consulta los viajes disponibles para más detalles.` },
];

const destinationPath = `/destino/${destination.slug}/`;
const pagePath = `/cuando-viajar-a/${destination.slug}/`;
const canonicalUrl = `${SITE_URL}${pagePath}`;
const seoImage = destination.seo?.ogImage || destination.heroImage;
const pageTitle = destination.seo?.cuandoViajarTitle || `¿Cuándo es la mejor época para viajar a ${destination.name}? — Travel Hood`;
const pageDescription = destination.seo?.cuandoViajarDescription || `Descubre cuándo viajar a ${destination.name}. ${destination.climate} Viajes en grupo desde ${minPrice > 0 ? minPrice + '€' : 'consultar'} con coordinador y alojamiento incluidos.`;
const pageKeywords = destination.seo?.keywords || `mejor época viajar ${destination.name}, cuando viajar a ${destination.name}, clima ${destination.name}, temporada ${destination.name}`;
---

<Layout title={pageTitle} description={pageDescription} heroImage={destination.heroImage} ogImage={seoImage} keywords={pageKeywords} canonical={canonicalUrl} ogUrl={canonicalUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={toJsonLd(generateBreadcrumbSchema([{name:"Home",url:"/"},{name:destination.name,url:destinationPath},{name:"Cuándo viajar",url:pagePath}]))} />
    <script type="application/ld+json" set:html={toJsonLd(generateFaqSchema(faqs))} />
  </Fragment>
  <main>
    <Navbar solid />

    <HeroSection
      image={destination.heroImage}
      imageAlt={heroAlt}
      breadcrumbs={[
        { label: "Home", href: "/" },
        { label: destination.name, href: `/destino/${destination.slug}/` },
        { label: "Cuándo viajar" },
      ]}
      title={`¿Cuándo es la mejor época para viajar a ${destination.name}?`}
      subtitle={destination.climate}
    />

    <section class="bg-card py-8">
      <div class="mx-auto max-w-4xl px-6">
        <div class="grid gap-5 rounded-3xl border border-border/40 bg-background p-5 shadow-sm sm:grid-cols-[1fr_auto] sm:items-center sm:p-6">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-secondary">Respuesta rápida</p>
            <h2 class="mt-2 font-serif text-xl font-extrabold text-foreground sm:text-2xl">
              {climateByMonth.some((month) => month.recommendation === "Ideal")
                ? `La mejor época para viajar a ${destination.name} depende del plan, pero estas fechas tienen meses recomendados como ideales.`
                : `La mejor época para viajar a ${destination.name} es la que encaja con una salida real y tu estilo de viaje.`}
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              {featuredTrip ? `La próxima salida disponible dura ${featuredTrip.durationDays} días, sale el ${new Date(featuredTrip.departureDate).toLocaleDateString("es-ES", { day: "numeric", month: "long", year: "numeric" })} y cuesta desde ${minPrice}€ sin vuelo.` : "Ahora mismo no hay salida disponible, pero puedes escribirnos para que te avisemos cuando abramos nuevas fechas."}
            </p>
          </div>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-destination-whatsapp
            data-page="cuando-viajar"
            data-destination={destination.slug}
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-[#25D366] px-6 py-3 text-sm font-extrabold text-white transition-all hover:-translate-y-0.5 hover:brightness-110"
          >
            Preguntar por WhatsApp
          </a>
        </div>
      </div>
    </section>

    <section class="bg-background py-16">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-6 text-center">
          ¿Qué clima encontrarás en {destination.name}?
        </h2>
        <div class="space-y-4 text-base leading-relaxed text-muted-foreground">
          <p>{destination.climate} {destination.name} ofrece experiencias únicas en cada temporada. Travel Hood selecciona las mejores fechas para cada destino.</p>
          <p>Un viaje en grupo a {destination.name} con Travel Hood cuesta desde {minPrice > 0 ? `${minPrice}€` : 'consultar precio'} por persona, sin incluir vuelos. El precio incluye alojamiento, transporte interno y coordinador.</p>
        </div>
      </div>
    </section>

    {hasClimateByMonth && (
      <section class="bg-card py-14">
        <div class="mx-auto max-w-5xl px-6">
          <h2 class="mb-3 text-center font-serif text-2xl font-extrabold text-foreground sm:text-3xl">
            Clima de {destination.name} mes a mes
          </h2>
          <p class="mx-auto mb-8 max-w-2xl text-center text-sm text-muted-foreground">
            Tabla pensada para decidir rápido: temperatura media, lluvia y recomendación de viaje.
          </p>
          <div class="overflow-hidden rounded-2xl border border-border/40 bg-background shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-full text-left text-sm">
                <thead class="bg-teal-deep text-sand">
                  <tr>
                    <th scope="col" class="px-4 py-3 font-bold">Mes</th>
                    <th scope="col" class="px-4 py-3 font-bold">Temperatura</th>
                    <th scope="col" class="px-4 py-3 font-bold">Lluvia</th>
                    <th scope="col" class="px-4 py-3 font-bold">Recomendación</th>
                    <th scope="col" class="px-4 py-3 font-bold">Nota</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-border/40">
                  {climateByMonth.map((month) => (
                    <tr>
                      <th scope="row" class="whitespace-nowrap px-4 py-3 font-bold text-foreground">{month.month}</th>
                      <td class="px-4 py-3 text-muted-foreground">{month.avgTemp || "Consultar"}</td>
                      <td class="px-4 py-3 text-muted-foreground">{month.rainfall || "Consultar"}</td>
                      <td class="px-4 py-3 font-semibold text-foreground">{month.recommendation || "Según fechas"}</td>
                      <td class="px-4 py-3 text-muted-foreground">{month.note || "Sin nota específica"}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>
    )}

    {destTrips.length > 0 && (
      <section class="bg-card py-14">
        <div class="mx-auto max-w-4xl px-6">
          <h2 class="font-serif text-2xl font-extrabold text-foreground sm:text-3xl mb-8 text-center">
            Viajes disponibles a {destination.name}
          </h2>
          <div class="space-y-4">
            {destTrips.map((trip) => {
              const { price } = resolvePrice(trip);
              return (
                <a href={`/destino/${destination.slug}/`} class="flex items-center justify-between rounded-xl border border-border/40 bg-background p-5 hover:shadow-md transition-all">
                  <div>
                    <p class="font-serif font-bold text-foreground">{trip.title}</p>
                    <p class="text-sm text-muted-foreground">{trip.durationDays} días · {trip.placesLeft} plazas</p>
                  </div>
                  <span class="text-lg font-bold text-teal-vivid">{price}€</span>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <GEODataBlock
      title={`${destination.name} — Datos de viaje`}
      subtitle={`Información clave para planificar tu viaje a ${destination.name}`}
      dataPoints={[
        { label: "Clima", value: destination.climate },
        { label: "Precio desde", value: minPrice > 0 ? `${minPrice}€ (sin vuelo)` : "Próximamente" },
        { label: "País", value: country.name },
        { label: "Continente", value: continent.name },
        { label: "Grupo medio", value: "12 a 13 personas de 20 a 35 años" },
      ]}
    />

    <FAQWrapper
      title={`Preguntas sobre cuándo viajar a ${destination.name}`}
      faqs={faqs}
    />

    <CTASection
      title={`¿Listo para viajar a ${destination.name}?`}
      subtitle="Escríbenos y te contamos fechas, grupo y presupuesto sin compromiso."
      ctaText="Pedir info por WhatsApp"
      ctaHref={whatsappUrl}
    />

    <script is:inline define:vars={{ destinationSlug: destination.slug }}>
      function hasAnalyticsConsent() {
        try {
          const match = document.cookie.match(/(?:^|; )th_cookie_consent=([^;]*)/);
          if (!match) return false;
          return JSON.parse(decodeURIComponent(match[1])).analytics === true;
        } catch {
          return false;
        }
      }

      document.querySelectorAll("[data-destination-whatsapp], a[href*='wa.me']").forEach((link) => {
        link.addEventListener("click", () => {
          if (!hasAnalyticsConsent()) return;
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "destination_whatsapp_click",
            destination_slug: link.getAttribute("data-destination") || destinationSlug,
            cta_location: link.getAttribute("data-cta-location") || "cuando_viajar_bottom_cta",
          });
        });
      });
    </script>

    <Footer />
  </main>
</Layout>
