---
import { getDestinations } from "@/lib/data-provider";

interface Props {
  bgImage?: string
  photo?: string
  photoAlt?: string
}
const { bgImage, photo, photoAlt } = Astro.props
const destinations = await getDestinations();
const destinationCount = destinations.length;
---

<section id="sobre-nosotros" class={`relative overflow-hidden py-14 ${!bgImage ? 'bg-teal-deep' : ''}`}>
  {bgImage && <img
    src={bgImage}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 h-full w-full object-cover"
    width="1920"
    height="1080"
    loading="lazy"
  />}
  <div class="absolute inset-0 bg-teal-deep/85"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-teal-deep/60 via-transparent to-teal-deep/70"></div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="flex flex-col items-center gap-12 lg:flex-row lg:gap-16">
      <!-- Image -->
      <div class="relative w-full max-w-lg lg:w-1/2">
        <div class="relative aspect-[4/5] overflow-hidden rounded-3xl">
          {photo ? (
            <img
              src={photo}
              alt={photoAlt || "Grupo de viajeros Travel Hood disfrutando juntos de un viaje en grupo"}
              class="h-full w-full object-cover"
              width="600"
              height="750"
              loading="lazy"
            />
          ) : (
            <div class="flex h-full w-full items-center justify-center bg-teal-deep/30">
              <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-sand/30"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path></svg>
            </div>
          )}
        </div>
        <div class="absolute -bottom-4 -right-4 z-10 rounded-2xl bg-sand/10 px-5 py-4 shadow-lg backdrop-blur-sm sm:-bottom-5 sm:-right-5">
          <p class="font-serif text-2xl font-extrabold text-coral">9/10</p>
          <p class="text-xs text-sand/70">repetirían</p>
        </div>
      </div>

      <!-- Text -->
      <div class="flex flex-col gap-6 lg:w-1/2">
        <span class="inline-block w-fit rounded-full bg-coral/15 px-3 py-1 text-xs font-bold uppercase tracking-widest text-coral">
          Sobre nosotros
        </span>
        <h2 class="font-serif text-3xl font-extrabold text-sand sm:text-4xl text-balance leading-tight">
          Llegas sin conocer a nadie.<br />Vuelves con una familia.
        </h2>
        <p class="text-base text-sand/80 leading-relaxed">
          Travel Hood nace de una verdad simple: hay miles de personas de 20 a 35 años que quieren viajar pero no tienen con quién. El freno no es el dinero, es la soledad. Nosotros rompemos esa barrera.
        </p>
        <p class="text-base text-sand/80 leading-relaxed">
          Creamos experiencias compartidas con itinerarios únicos, coordinador en destino y una comunidad que se convierte en algo real. No somos una agencia corporativa. Somos viajeros que organizan viajes para viajeros.
        </p>

        <blockquote class="border-l-4 border-coral pl-4">
          <p class="text-base font-medium text-sand italic leading-relaxed">
            "Fui sin conocer a nadie. Volví con gente que ya considero amigos."
          </p>
          <footer class="mt-2 text-sm text-sand/60">
            — Laura, 28 años, Madrid
          </footer>
        </blockquote>

        <div class="mt-2 grid grid-cols-2 gap-4">
          <div class="rounded-xl bg-sand/10 p-4 text-center backdrop-blur-sm">
            <p class="font-serif text-2xl font-extrabold text-coral">+500</p>
            <p class="mt-1 text-xs text-sand/70">Viajeros</p>
          </div>
          <div class="rounded-xl bg-sand/10 p-4 text-center backdrop-blur-sm">
            <p class="font-serif text-2xl font-extrabold text-coral">{destinationCount}</p>
            <p class="mt-1 text-xs text-sand/70">Destinos</p>
          </div>
        </div>

        <a
          href="/viajes/#resultados"
          class="mt-2 inline-flex w-fit items-center gap-2 rounded-full bg-coral px-6 py-3 text-sm font-bold text-accent-foreground transition-all hover:brightness-110"
        >
          Ver próximos viajes
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
