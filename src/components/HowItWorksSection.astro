---
const steps = [
  {
    icon: "search",
    step: "01",
    title: "Elige tu destino",
    description: "Explora nuestros viajes y encuentra el que más te llame.",
  },
  {
    icon: "calendar-check",
    step: "02",
    title: "Reserva tu plaza",
    description: "Rellena un formulario simple y asegura tu sitio en el grupo.",
  },
  {
    icon: "plane",
    step: "03",
    title: "Prepara la maleta",
    description: "Te mandamos toda la info. Tú solo preocúpate de hacer la maleta.",
  },
  {
    icon: "heart",
    step: "04",
    title: "Vive la experiencia",
    description: "Llegas solo y vuelves con amigos. Así de simple.",
  },
];

const icons: Record<string, string> = {
  search: '<circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path>',
  "calendar-check": '<path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path><path d="m9 16 2 2 4-4"></path>',
  plane: '<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"></path>',
  heart: '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>',
};
---

<section id="como-funciona" class="relative overflow-hidden py-14">
  <img
    src="/images/hero-laponia.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 h-full w-full object-cover"
    width="1920"
    height="1080"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-teal-deep/85"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-teal-deep/50 via-transparent to-teal-deep/70"></div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="mb-10 text-center">
      <span class="inline-block rounded-full bg-coral/15 px-3 py-1 text-xs font-bold uppercase tracking-widest text-coral">
        Cómo funciona
      </span>
      <h2 class="mt-3 font-serif text-2xl font-extrabold text-sand sm:text-3xl text-balance">
        De pensarlo a vivirlo en 4 pasos
      </h2>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((item, index) => (
        <div class="relative flex flex-col items-center gap-4 rounded-2xl bg-sand/10 p-6 text-center backdrop-blur-sm transition-all hover:-translate-y-1 hover:bg-sand/15">
          {index < steps.length - 1 && (
            <div class="absolute top-11 left-[calc(100%+2px)] hidden h-0.5 w-[calc(24px)] bg-sand/20 lg:block" />
          )}

          <div class="relative flex h-[72px] w-[72px] items-center justify-center rounded-2xl bg-sand/15 text-sand">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[item.icon]} />
            <span class="absolute -top-2 -right-2 flex h-7 w-7 items-center justify-center rounded-full bg-coral text-xs font-bold text-accent-foreground">
              {item.step}
            </span>
          </div>

          <h3 class="font-serif text-lg font-bold text-sand">{item.title}</h3>
          <p class="text-sm text-sand/70 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
