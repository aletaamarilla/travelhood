---
import { FALLBACK_WHATSAPP_PHONE, buildWhatsAppUrl } from "@/lib/config";
import { getSiteSettings, getDepositAmount } from "@/lib/data-provider";
const [settings, depositAmount] = await Promise.all([getSiteSettings(), getDepositAmount()]);
const waPhone = settings?.whatsappPhone ?? FALLBACK_WHATSAPP_PHONE;
---

<section class="relative overflow-hidden bg-gradient-to-br from-teal-deep via-[#0d3845] to-teal-deep py-20">
  <div class="absolute top-0 right-0 h-64 w-64 rounded-full bg-teal-vivid/10 blur-3xl"></div>
  <div class="absolute bottom-0 left-0 h-48 w-48 rounded-full bg-coral/10 blur-3xl"></div>

  <div class="relative mx-auto flex max-w-3xl flex-col items-center gap-8 px-6 text-center">
    <span class="text-xs font-bold uppercase tracking-widest text-yellow-sun">
      No te quedes en casa
    </span>
    <h2 class="font-serif text-3xl font-extrabold text-sand sm:text-4xl lg:text-5xl text-balance leading-tight">
      El grupo ya se está formando.
      <br />
      Solo falta tu nombre.
    </h2>
    <p class="max-w-xl text-base text-sand/80 leading-relaxed">
      Elige un destino, reserva tu plaza y déjanos el resto. No necesitas
      plan, no necesitas compañía. Solo necesitas decidir.
    </p>
    <div class="flex flex-col gap-4 sm:flex-row">
      <a
        href="/viajes/#resultados"
        class="inline-flex items-center justify-center rounded-full bg-coral px-8 py-3.5 text-base font-bold text-white transition-all hover:brightness-110"
      >
        Ver próximos viajes
      </a>
      <a
        href={buildWhatsAppUrl(waPhone)}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-8 py-3.5 text-base font-bold text-white transition-all hover:brightness-110"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Hablar por WhatsApp
      </a>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-sand/60">
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        Reserva desde {depositAmount}€
      </span>
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        Cancelación flexible
      </span>
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        Coordinador incluido
      </span>
    </div>
  </div>
</section>
