---
import { getDestinations, getFeaturedTestimonials, getSiteSettings } from "@/lib/data-provider";
import { getTrustpilotProfileLink } from "@/lib/reviews";
import ReviewCard from "@/components/ReviewCard.astro";

const [testimonials, destinations, settings] = await Promise.all([
  getFeaturedTestimonials(),
  getDestinations(),
  getSiteSettings(),
]);

const featuredTestimonials = testimonials.slice(0, 6);
const destinationsById = new Map(destinations.map((destination) => [destination.id, destination]));
const trustpilotProfileHref = getTrustpilotProfileLink(settings?.trustpilotProfileUrl);
const attributionText =
  settings?.reviewsAttributionText?.trim() ||
  (trustpilotProfileHref
    ? "También puedes leer más opiniones en nuestro perfil público de Trustpilot."
    : "Opiniones reales de viajeros que ya han viajado con Travel Hood.");
const trustpilotCtaLabel = settings?.reviewsCtaLabel?.trim() || "Ver opiniones en Trustpilot";
---

{featuredTestimonials.length > 0 && (
  <section id="testimonios" class="bg-background py-16">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <span class="inline-block rounded-full bg-coral/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-coral">
          Opiniones reales
        </span>
        <h2 class="mt-3 font-serif text-2xl font-extrabold text-foreground sm:text-3xl text-balance">
          Viajeros que se atrevieron a reservar sin conocer a nadie
        </h2>
        <p class="mt-4 text-base leading-relaxed text-muted-foreground">
          Experiencias reales de quienes ya viajaron con Travel Hood y volvieron con una historia que contar.
        </p>
      </div>

      <div class="scrollbar-hide flex snap-x snap-mandatory gap-4 overflow-x-auto pb-4 sm:grid sm:snap-none sm:grid-cols-2 sm:overflow-visible sm:pb-0 lg:grid-cols-3 sm:gap-6">
        {featuredTestimonials.map((testimonial) => {
          const destination = testimonial.destinationId ? destinationsById.get(testimonial.destinationId) : undefined;
          return (
            <ReviewCard
              review={testimonial}
              destinationName={destination?.name}
              destinationPrefix="Viajó a"
              class="w-[76vw] max-w-[310px] flex-shrink-0 snap-start sm:w-auto sm:max-w-none sm:flex-shrink"
            />
          );
        })}
      </div>

      <div class="mt-8 flex flex-col items-center justify-center gap-4 text-center">
        <p class="max-w-2xl text-xs leading-relaxed text-muted-foreground">
          {attributionText}
        </p>
        <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href="/opiniones/"
            class="inline-flex items-center justify-center rounded-full bg-coral px-6 py-3 text-sm font-bold text-white transition-all hover:brightness-110"
          >
            Leer todas las opiniones
          </a>
          {trustpilotProfileHref && (
            <a
              href={trustpilotProfileHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-full border border-teal-deep/20 px-6 py-3 text-sm font-bold text-teal-deep transition-colors hover:border-teal-deep/40 hover:bg-teal-deep/5"
            >
              {trustpilotCtaLabel}
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
)}
