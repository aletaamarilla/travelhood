---
import { getTestimonials, getDestinations } from "@/lib/data-provider";
const [testimonials, destinations] = await Promise.all([getTestimonials(), getDestinations()]);
---

<section id="testimonios" class="bg-background py-14">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-10 text-center">
      <span class="inline-block rounded-full bg-coral/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-coral">
        Testimonios reales
      </span>
      <h2 class="mt-3 font-serif text-2xl font-extrabold text-foreground sm:text-3xl text-balance">
        Lo dicen ellos, no nosotros
      </h2>
      <p class="mt-4 text-base text-muted-foreground">
        Personas reales. Experiencias reales. Sin filtro.
      </p>
    </div>

    <div class="scrollbar-hide flex snap-x snap-mandatory gap-4 overflow-x-auto pb-4 sm:grid sm:snap-none sm:grid-cols-2 sm:overflow-visible sm:pb-0 lg:grid-cols-3 sm:gap-6">
      {testimonials.slice(0, 6).map((t) => {
        const dest = destinations.find((d) => d.id === t.destinationId);
        const initials = t.name.charAt(0);
        return (
          <article class="group relative w-[68vw] max-w-[280px] flex-shrink-0 snap-start flex flex-col rounded-2xl border border-border/60 bg-card p-5 shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl sm:w-auto sm:max-w-none sm:flex-shrink sm:p-6">
            <div class="absolute top-0 left-6 right-6 h-1 rounded-b-full bg-gradient-to-r from-coral to-yellow-sun"></div>

            <div class="mb-4 flex items-center gap-0.5">
              {Array.from({ length: t.rating }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-yellow-sun">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              ))}
            </div>

            <blockquote class="mb-5 flex-1">
              <p class="font-serif text-[15px] font-semibold text-foreground leading-relaxed">
                "{t.quote}"
              </p>
            </blockquote>

            <div class="flex items-center gap-3 border-t border-border/40 pt-4">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-teal-deep text-xs font-bold text-sand">
                {initials}
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-bold text-foreground">
                  {t.name}, {t.age} años
                </p>
                <p class="text-xs text-muted-foreground">{t.city}</p>
              </div>
              {dest && (
                <span class="shrink-0 rounded-full bg-coral/10 px-2.5 py-1 text-[11px] font-semibold text-coral">
                  {dest.name}
                </span>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
