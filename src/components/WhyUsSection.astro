---
const reasons = [
  {
    title: "Grupo real, no turistas random",
    description:
      "Viajeros de 20-35 años con ganas de vivir algo único. El grupo se convierte en familia antes de aterrizar.",
    icon: "users",
  },
  {
    title: "Itinerarios que no están en Google",
    description:
      "Destinos únicos con experiencias locales. Nada de tours masificados ni rutas típicas.",
    icon: "map",
  },
  {
    title: "Coordinador en destino",
    description:
      "Alguien del equipo viaja contigo. Gestiona, resuelve y se asegura de que todo fluya.",
    icon: "headphones",
  },
  {
    title: "Todo organizado, sin sorpresas",
    description:
      "Alojamiento, transporte y actividades. Tú solo decides lanzarte.",
    icon: "shield",
  },
];

const icons: Record<string, string> = {
  users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>',
  map: '<path d="m3 6 6-3 6 3 6-3v15l-6 3-6-3-6 3z"></path><path d="M9 3v15"></path><path d="M15 6v15"></path>',
  headphones: '<path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"></path>',
  shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>',
};
---

<section class="relative overflow-hidden py-14">
  <img
    src="/images/hero-zanzibar.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 h-full w-full object-cover"
    width="1920"
    height="1080"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-teal-deep/85"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-teal-deep/60 via-transparent to-teal-deep/80"></div>
  <div class="relative mx-auto max-w-4xl px-6">
    <div class="mb-10 text-center">
      <span class="text-xs font-bold uppercase tracking-widest text-coral">
        Por qué Travelhood
      </span>
      <h2 class="mt-3 font-serif text-2xl font-extrabold text-sand sm:text-3xl text-balance">
        No es solo un viaje. Es la experiencia que te cambia.
      </h2>
    </div>

    <div class="grid gap-10 sm:grid-cols-2">
      {reasons.map((reason) => (
        <div class="flex items-start gap-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-sand/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-yellow-sun" set:html={icons[reason.icon]} />
          </div>
          <div>
            <h3 class="text-sm font-bold text-sand">{reason.title}</h3>
            <p class="mt-1 text-sm text-sand/70 leading-relaxed">{reason.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
