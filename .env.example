# Sanity CMS (público - necesario para build)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2026-03-16

# Sanity Token (solo para scripts CLI - NUNCA en frontend)
# SANITY_TOKEN=

# Google Tag Manager (público - se inyecta en el HTML)
PUBLIC_GTM_ID=

# URL pública del sitio (necesaria antes de conectar a Sanity)
PUBLIC_SITE_URL=https://travelhood.es

# Sanity Studio App ID (deployment)
SANITY_STUDIO_APP_ID=
